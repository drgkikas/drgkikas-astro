{
	"compatibility_date": "2026-03-29",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "drgkikas-astro",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "psychometrika",
			"database_id": "e34e1613-8ea4-4f0a-b458-dc694575e420"
		}
	]
}