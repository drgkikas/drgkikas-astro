---
export const prerender = true;
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/UI/Header.astro';
import Footer from '../../components/UI/Footer.astro';

import { getEntry } from 'astro:content';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map(s => ({ params: { slug: s.id.toLowerCase() } }));
}

const { slug } = Astro.params;
const entry = await getEntry('services', slug) || (await getCollection('services')).find(s => s.id.toLowerCase() === slug);
if (!entry) return Astro.redirect('/404');
const { Content } = await render(entry);

const canonicalURL = new URL(Astro.url.pathname, 'https://drgkikas.com').href;
const schemaBundle = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "MedicalProcedure",
      "name": entry.data.title,
      "description": entry.data.description,
      "url": canonicalURL
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Αρχική", "item": "https://drgkikas.com/" },
        { "@type": "ListItem", "position": 2, "name": "Υπηρεσίες", "item": "https://drgkikas.com/ypiresies" },
        { "@type": "ListItem", "position": 3, "name": entry.data.title, "item": canonicalURL }
      ]
    }
  ]
});
---

<Layout title={entry.data.title} description={entry.data.description} schema={schemaBundle}>
  <Header />
  <main class="pt-24 pb-16 bg-slate-50 min-h-screen">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Breadcrumbs UI -->
      <nav class="text-sm text-slate-500 mb-8 mt-4">
        <ol class="list-none p-0 inline-flex flex-wrap items-center">
          <li class="flex items-center"><a href="/" class="hover:text-blue-700 transition-colors">Αρχική</a><svg class="w-3 h-3 mx-2 opacity-50" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path></svg></li>
          <li class="flex items-center"><a href="/ypiresies/" class="hover:text-blue-700 transition-colors">Υπηρεσίες</a><svg class="w-3 h-3 mx-2 opacity-50" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path></svg></li>
          <li class="flex items-center"><span class="text-slate-800 font-medium">{entry.data.title}</span></li>
        </ol>
      </nav>

      <div class="glass-card p-10 md:p-16">
        <div class="text-center mb-16 border-b border-slate-200 pb-12">
          <h1 class="text-4xl md:text-5xl font-bold text-blue-900 mb-8 leading-normal" set:html={entry.data.title}></h1>
          <p class="text-xl md:text-2xl text-slate-600 leading-relaxed max-w-3xl mx-auto">{entry.data.description}</p>
        </div>
        
        <div class="prose prose-lg md:prose-xl prose-blue max-w-none text-slate-700
          prose-p:mb-10 prose-p:leading-[1.9]
          prose-headings:text-blue-900 prose-headings:font-bold 
          prose-h2:mt-20 prose-h2:mb-8 prose-h2:border-b prose-h2:border-slate-100 prose-h2:pb-4
          prose-h3:mt-14 prose-h3:mb-6
          prose-a:font-bold prose-a:text-blue-900 prose-a:bg-blue-100 prose-a:px-2 prose-a:py-0.5 prose-a:rounded-lg prose-a:no-underline hover:prose-a:bg-blue-700 hover:prose-a:text-white prose-a:transition-colors
          prose-ul:my-10 prose-li:my-5 marker:text-blue-500">
          <Content />
        </div>

        {/* ΔΥΝΑΜΙΚΑ INTERNAL LINKS ΓΙΑ SEO */}
        <div class="mt-20 pt-12 border-t border-slate-200">
          <h2 class="text-2xl font-bold text-blue-900 mb-8">Σχετικές Καταστάσεις & Διαγνώσεις</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {slug === 'rtms' && (
              <>
                <a href="/diataraxes/katathlipsi/" class="p-6 bg-blue-50 rounded-2xl border border-blue-100 hover:border-blue-300 transition-all font-bold text-blue-900">Κατάθλιψη (MDD) &rarr;</a>
                <a href="/diataraxes/ideopsychanagkastiki-diatarachi/" class="p-6 bg-blue-50 rounded-2xl border border-blue-100 hover:border-blue-300 transition-all font-bold text-blue-900">Ιδεοψυχαναγκαστική Διαταραχή &rarr;</a>
              </>
            )}
            {slug === 'pgx' && (
              <>
                <a href="/diataraxes/katathlipsi/" class="p-6 bg-blue-50 rounded-2xl border border-blue-100 hover:border-blue-300 transition-all font-bold text-blue-900">Κατάθλιψη (MDD) &rarr;</a>
                <a href="/diataraxes/agxodeis-diataraxes/" class="p-6 bg-blue-50 rounded-2xl border border-blue-100 hover:border-blue-300 transition-all font-bold text-blue-900">Αγχώδεις Διαταραχές &rarr;</a>
                <a href="/diataraxes/dipoliki-diatarachi/" class="p-6 bg-blue-50 rounded-2xl border border-blue-100 hover:border-blue-300 transition-all font-bold text-blue-900">Διπολική Διαταραχή &rarr;</a>
              </>
            )}
            {!['rtms', 'pgx'].includes(slug) && (
              <>
                <a href="/diataraxes/katathlipsi/" class="p-6 bg-blue-50 rounded-2xl border border-blue-100 hover:border-blue-300 transition-all font-bold text-blue-900">Κατάθλιψη (MDD) &rarr;</a>
                <a href="/diataraxes/agxodeis-diataraxes/" class="p-6 bg-blue-50 rounded-2xl border border-blue-100 hover:border-blue-300 transition-all font-bold text-blue-900">Αγχώδεις Διαταραχές &rarr;</a>
              </>
            )}
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
