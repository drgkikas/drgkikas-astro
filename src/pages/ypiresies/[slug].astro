---
export const prerender = true;
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/UI/Header.astro';
import Footer from '../../components/UI/Footer.astro';

import { getEntry } from 'astro:content';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map(s => ({ params: { slug: s.id } }));
}

const { slug } = Astro.params;
const entry = await getEntry('services', slug);
if (!entry) return Astro.redirect('/404');
const { Content } = await render(entry);
  const canonicalURL = new URL(Astro.url.pathname, 'https://drgkikas.com').href;
  const schemaBundle = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "MedicalProcedure",
    "name": entry.data.title,
    "description": entry.data.description,
    "url": canonicalURL
  });
---

<Layout title={entry.data.title} description={entry.data.description} schema={schemaBundle}>
  <Header />
  <main class="pt-24 pb-16 bg-slate-50 min-h-screen">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="glass-card p-10 md:p-16 mt-8">
        <div class="text-center mb-16 border-b border-slate-200 pb-12">
          <h1 class="text-4xl md:text-5xl font-bold text-blue-900 mb-8 leading-normal" set:html={entry.data.title}></h1>
          <p class="text-xl md:text-2xl text-slate-600 leading-relaxed max-w-3xl mx-auto">{entry.data.description}</p>
        </div>
        
        <div class="prose prose-lg md:prose-xl prose-blue max-w-none text-slate-700
          prose-p:mb-10 prose-p:leading-[1.9]
          prose-headings:text-blue-900 prose-headings:font-bold 
          prose-h2:mt-20 prose-h2:mb-8 prose-h2:border-b prose-h2:border-slate-100 prose-h2:pb-4
          prose-h3:mt-14 prose-h3:mb-6
          prose-a:font-bold prose-a:text-blue-900 prose-a:bg-blue-100 prose-a:px-2 prose-a:py-0.5 prose-a:rounded-lg prose-a:no-underline hover:prose-a:bg-blue-700 hover:prose-a:text-white prose-a:transition-colors
          prose-ul:my-10 prose-li:my-5 marker:text-blue-500">
          <Content />
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
