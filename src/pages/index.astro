---
import Layout from '../layouts/Layout.astro';
import Header from '../components/UI/Header.astro';
import Hero from '../components/UI/Hero.astro';
import Footer from '../components/UI/Footer.astro';
import Dass21 from '../components/Tests/Dass21';
---

<Layout title="Αρχική">
  <Header />
  <main>
    <Hero />
    
    <section id="tests" class="py-24 bg-white relative">
      <div class="absolute inset-0 bg-gradient-to-b from-slate-50 to-white -z-10 h-32"></div>
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <span class="text-teal-600 font-semibold tracking-wider text-sm uppercase">Interactive Tool</span>
          <h2 class="text-4xl font-bold text-slate-900 mt-2 mb-6">Ψυχομετρικά Web-Tests</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Συμπληρώστε το τεστ DASS-21 για μια γρήγορη αξιολόγηση των επιπέδων Κατάθλιψης, Άγχους και Στρες. 
            <strong>Τα δεδομένα σας υφίστανται επεξεργασία 100% τοπικά στη συσκευή σας και ΔΕΝ αποθηκεύονται πουθενά (Zero-Data Retention).</strong>
          </p>
        </div>
        
        <!-- React Component Hydration -->
        <div class="shadow-2xl shadow-slate-200/50 rounded-2xl">
          <Dass21 client:load />
        </div>
      </div>
    </section>

    <!-- Library/Resources Placeholder -->
    <section class="py-24 bg-slate-50 border-t border-slate-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl font-bold text-slate-900 mb-4">Βιβλιοθήκη & Οδηγοί</h2>
        <p class="text-slate-600 mb-8 max-w-2xl mx-auto">
          Σύντομα θα προστεθεί το υλικό μας με δωρεάν PDF οδηγούς αλλά και E-books για βαθύτερη κατανόηση της Νευροτροποποίησης.
        </p>
        <button class="btn-secondary opacity-50 cursor-not-allowed">Επερχόμενη Προσθήκη (Stripe)</button>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
