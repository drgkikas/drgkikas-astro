---
import Layout from '../layouts/Layout.astro';
import Header from '../components/UI/Header.astro';
import Footer from '../components/UI/Footer.astro';

const schemaBundle = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Physician",
      "@id": "https://drgkikas.gr/#physician",
      "name": "Πασχάλης Γκίκας",
      "medicalSpecialty": "Psychiatry",
      "url": "https://drgkikas.gr"
    },
    {
      "@type": "MedicalClinic",
      "@id": "https://drgkikas.gr/#clinic",
      "name": "Smart CNS Center",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Ξενοφώντος 15Α",
        "addressLocality": "Αθήνα",
        "postalCode": "105 57",
        "addressCountry": "GR"
      },
      "telephone": "2118500016"
    },
    {
      "@type": "WebSite",
      "@id": "https://drgkikas.gr/#website",
      "url": "https://drgkikas.gr",
      "name": "Δρ. Πασχάλης Γκίκας - Ψυχίατρος"
    }
  ]
});
---

<Layout schema={schemaBundle} 
  title="Πασχάλης Γκίκας | Ψυχίατρος Αθήνα | rTMS & Φαρμακογονιδιωματική" 
  description="Πασχάλης Γκίκας — Ψυχίατρος στην Αθήνα. Εξειδικευμένες υπηρεσίες rTMS, Φαρμακογονιδιωματικής και Ψυχοθεραπείας στο Smart CNS Center."
>
  <Header />

  <main>
    <!-- ΕΝΟΤΗΤΑ 1: HERO (IDEAL WIREFRAME) -->
    <section class="relative bg-white pt-40 pb-24 overflow-hidden border-b border-slate-100">
      <!-- Background subtle elements -->
      <div class="absolute inset-0 bg-[radial-gradient(#f1f5f9_1px,transparent_1px)] [background-size:24px_24px] opacity-50"></div>
      
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 flex flex-col items-center">
        <div class="lg:w-4/5 mx-auto text-center">
          
          <!-- Eyebrow -->
          <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-slate-50 border border-slate-200 text-slate-500 font-medium text-sm mb-8">
            <span class="w-1.5 h-1.5 rounded-full bg-blue-600 animate-pulse"></span>
            Ψυχίατρος στην Αθήνα • Smart CNS Center
          </div>
          
          <!-- H1 -->
          <h1 class="text-4xl md:text-5xl lg:text-7xl font-extrabold text-slate-900 leading-tight mb-10 tracking-tight">
            Πασχάλης Γκίκας, <br class="hidden md:block"/>
            <span class="text-[#084a79]">Ψυχίατρος στην Αθήνα</span>
          </h1>
          
          <!-- Intro Paragraph -->
          <p class="text-xl md:text-2xl text-slate-600 mb-12 leading-relaxed max-w-4xl mx-auto font-light">
            Είμαι ο <strong>Πασχάλης Γκίκας</strong>, Ψυχίατρος-Ψυχοθεραπευτής και Ιατρικός Διευθυντής του Smart CNS Center στην Αθήνα. Για κάθε ασθενή σχεδιάζω θεραπεία βασισμένη στη δική του βιολογία — μέσω <strong>Φαρμακογονιδιωματικής</strong> και <strong>rTMS</strong>. Επιστήμη αντί για τύχη. Λιγότερες δοκιμές, περισσότερες απαντήσεις.
          </p>
          
          <!-- Primary CTA Row -->
          <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-12">
            <a href="/epikoinonia" class="w-full sm:w-auto px-10 py-5 bg-[#084a79] hover:bg-[#063557] text-white rounded-2xl font-black transition-all shadow-xl shadow-blue-900/10 text-lg">
              Κλείστε Ραντεβού
            </a>
            <a href="/ypiresies" class="w-full sm:w-auto px-10 py-5 bg-slate-50 border border-slate-200 text-slate-700 hover:bg-white rounded-2xl font-bold transition-all text-lg">
              Δείτε τις Υπηρεσίες
            </a>
            <a href="/rtms" class="w-full sm:w-auto px-10 py-5 bg-white border-2 border-slate-100 text-[#084a79] hover:border-blue-200 rounded-2xl font-bold transition-all text-lg">
              Μάθετε για το rTMS
            </a>
          </div>

          <!-- Trust/Support Link Row -->
          <div class="flex flex-wrap justify-center items-center gap-x-8 gap-y-4 pt-8 border-t border-slate-100">
            <a href="/iatros" class="text-sm font-bold text-slate-400 hover:text-[#084a79] transition-colors">Βιογραφικό</a>
            <span class="hidden sm:inline w-1 h-1 rounded-full bg-slate-200"></span>
            <a href="/epikoinonia" class="text-sm font-bold text-slate-400 hover:text-[#084a79] transition-colors">Επικοινωνία</a>
            <span class="hidden sm:inline w-1 h-1 rounded-full bg-slate-200"></span>
            <a href="/psychometrika" class="text-sm font-bold text-slate-400 hover:text-[#084a79] transition-colors">Ψυχομετρικά Τεστ</a>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 1: ΒΑΣΙΚΕΣ ΥΠΗΡΕΣΙΕΣ -->
    <section class="py-24 bg-[#f8fafc]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <span class="text-[#084a79] font-bold tracking-widest text-xs uppercase mb-2 block">Υπηρεσίες</span>
          <h2 class="text-3xl md:text-5xl font-bold text-slate-900">Τρεις Πυλώνες Θεραπείας</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Card 1: rTMS -->
          <div class="flex flex-col p-10 rounded-3xl bg-white border border-slate-100 shadow-sm hover:shadow-xl transition-all h-full">
            <div class="w-14 h-14 bg-red-50 text-red-700 rounded-xl flex items-center justify-center text-2xl mb-8">🧲</div>
            <h3 class="text-2xl font-bold text-slate-900 mb-4">rTMS — Νευροτροποποίηση</h3>
            <p class="text-slate-600 leading-relaxed mb-8 flex-grow">Εγκεκριμένη, μη επεμβατική θεραπεία για ανθεκτική κατάθλιψη, OCD και εξαρτήσεις. Στοχευμένη διέγερση νευρικών κυκλωμάτων χωρίς φάρμακα.</p>
            <a href="/rtms" aria-label="Περισσότερα για τις θεραπείες rTMS" class="group flex items-center gap-2 text-[#084a79] font-black hover:gap-3 transition-all duration-300">
              Περισσότερα για το rTMS
              <span>&rarr;</span>
            </a>
          </div>

          <!-- Card 2: PGx -->
          <div class="flex flex-col p-10 rounded-3xl bg-white border border-slate-100 shadow-sm hover:shadow-xl transition-all h-full">
            <div class="w-14 h-14 bg-blue-50 text-blue-700 rounded-xl flex items-center justify-center text-2xl mb-8">🧬</div>
            <h3 class="text-2xl font-bold text-slate-900 mb-4">Φαρμακογονιδιωματική</h3>
            <p class="text-slate-600 leading-relaxed mb-8 flex-grow">Ανάλυση DNA για την επιλογή της καταλληλότερης φαρμακευτικής αγωγής. Σωστό φάρμακο και σωστή δόση από την πρώτη στιγμή.</p>
            <a href="/pgx" aria-label="Περισσότερα για την Φαρμακογονιδιωματική" class="group flex items-center gap-2 text-[#084a79] font-black hover:gap-3 transition-all duration-300">
              Ανάλυση PGx
              <span>&rarr;</span>
            </a>
          </div>

          <!-- Card 3: Clinical -->
          <div class="flex flex-col p-10 rounded-3xl bg-white border border-slate-100 shadow-sm hover:shadow-xl transition-all h-full">
            <div class="w-14 h-14 bg-purple-50 text-purple-700 rounded-xl flex items-center justify-center text-2xl mb-8">🩺</div>
            <h3 class="text-2xl font-bold text-slate-900 mb-4">Κλινική Ψυχιατρική</h3>
            <p class="text-slate-600 leading-relaxed mb-8 flex-grow">Ολοκληρωμένη διαγνωστική αξιολόγηση, ψυχοθεραπεία και συνεδρίες (δια ζώσης ή online) για την πλήρη υποστήριξη της ψυχικής υγείας.</p>
            <a href="/ypiresies" aria-label="Δείτε όλες τις κλινικές υπηρεσίες" class="group flex items-center gap-2 text-[#084a79] font-black hover:gap-3 transition-all duration-300">
              Όλες οι Υπηρεσίες
              <span>&rarr;</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 2: ΓΙΑΤΙ SMART CNS / ΦΙΛΟΣΟΦΙΑ -->
    <section class="py-24 bg-white overflow-hidden relative">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
          <div>
            <span class="text-[#084a79] font-bold tracking-widest text-xs uppercase mb-4 block">Γιατί Εμάς</span>
            <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-8 leading-tight">Πέρα από τη Μέθοδο "Δοκιμής και Σφάλματος"</h2>
            <div class="prose prose-lg text-slate-600 font-light leading-relaxed space-y-6">
              <p>
                Κάθε εγκέφαλος είναι βιολογικά μοναδικός. Η κλασική προσέγγιση της δοκιμής φαρμάκων κοστίζει χρόνο και ψυχικές δυνάμεις.
              </p>
              <p>
                Στο ιατρείο μας, ξεκινάμε από τα <strong>αντικειμενικά δεδομένα σας</strong>. Συνδυάζουμε γενετικά και ψυχομετρικά στοιχεία για να σχεδιάσουμε ένα πλάνο που αποδίδει άμεσα.
              </p>
              <ul class="list-none p-0 mt-8 space-y-4">
                <li class="flex items-center gap-3 text-slate-900 font-bold">
                  <span class="w-6 h-6 rounded-full bg-green-100 text-green-700 flex items-center justify-center text-xs">✓</span>
                  Προστασία από περιττές παρενέργειες
                </li>
                <li class="flex items-center gap-3 text-slate-900 font-bold">
                  <span class="w-6 h-6 rounded-full bg-green-100 text-green-700 flex items-center justify-center text-xs">✓</span>
                  Ταχύτερη επίτευξη της ύφεσης
                </li>
                <li class="flex items-center gap-3 text-slate-900 font-bold">
                  <span class="w-6 h-6 rounded-full bg-green-100 text-green-700 flex items-center justify-center text-xs">✓</span>
                  Συνεχής ποσοτική παρακολούθηση προόδου
                </li>
              </ul>
            </div>
          </div>
          <div class="relative">
            <div class="absolute -inset-10 bg-blue-50 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-pulse"></div>
            <div class="relative bg-slate-900 rounded-[3rem] p-12 text-white shadow-2xl">
              <div class="text-4xl mb-6">🧬</div>
              <h3 class="text-2xl font-bold mb-4">Ψυχιατρική Ακριβείας</h3>
              <p class="text-slate-400 text-lg leading-relaxed mb-8">
                Δεν βασιζόμαστε μόνο στην υποκειμενική εκτίμηση. Επενδύουμε στην τεχνολογία και τη βιολογία για να απαντήσουμε στο "γιατί" πριν προτείνουμε το "πώς".
              </p>
              <div class="pt-8 border-t border-white/10 flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-slate-800 flex items-center justify-center font-bold">PGk</div>
                <div>
                  <div class="font-bold">Πασχάλης Γκίκας</div>
                  <div class="text-xs text-slate-500 uppercase">Ιατρικός Διευθυντής</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 3: ΣΕ ΠΟΙΕΣ ΚΑΤΑΣΤΑΣΕΙΣ ΒΟΗΘΑΜΕ -->
    <section class="py-24 bg-slate-50 border-y border-slate-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <span class="text-[#084a79] font-bold tracking-widest text-xs uppercase mb-2 block">Ενδείξεις</span>
          <h2 class="text-3xl md:text-5xl font-bold text-slate-900">Πώς Μπορούμε να Βοηθήσουμε</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-5xl mx-auto">
          {[
            { t: "Ανθεκτική Κατάθλιψη", l: "/diataraxes/katathlipsi" },
            { t: "Ιδεοψυχαναγκαστική Διαταραχή (OCD)", l: "/rtms/endixeis/ocd" },
            { t: "Γενικευμένη Αγχώδης Διαταραχή", l: "/diataraxes/agnosi-aitia" },
            { t: "Διπολική Διαταραχή", l: "/rtms/endixeis/dipoliki" },
            { t: "Εξαρτήσεις (Κάπνισμα, Αλκοόλ)", l: "/rtms/endixeis/exartiseis" },
            { t: "Χρόνιος Πόνος & Ινομυαλγία", l: "/rtms/endixeis/ponos" }
          ].map(item => (
            <a href={item.l} class="flex items-center justify-between p-6 bg-white border border-slate-100 rounded-2xl hover:border-blue-300 hover:shadow-md transition-all group">
              <span class="font-bold text-slate-800 text-lg">{item.t}</span>
              <span class="text-slate-300 group-hover:text-blue-600 transition-colors">&rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- SECTION 4: FEATURED PATH — RTMS -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="relative rounded-[3rem] bg-gradient-to-br from-[#084a79] to-[#042a46] p-12 md:p-20 overflow-hidden shadow-2xl">
          <div class="absolute top-0 right-0 w-1/3 h-full bg-white/5 skew-x-12 transform translate-x-1/2"></div>
          
          <div class="relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div>
              <div class="inline-block px-4 py-1 rounded-full bg-red-600 text-white text-xs font-black uppercase mb-6">Expertise</div>
              <h2 class="text-4xl md:text-6xl font-extrabold text-white mb-8 leading-tight">rTMS: Η Επανάσταση στη Νευροδιαβίβαση</h2>
              <p class="text-blue-100 text-xl leading-relaxed mb-10 font-light">
                Μια μη επεμβατική μέθοδος που αλλάζει τα δεδομένα για όσους δεν είδαν αποτέλεσμα με τη φαρμακοθεραπεία. Χωρίς παρενέργειες, χωρίς αναισθησία.
              </p>
              <div class="flex flex-wrap gap-4">
                <a href="/rtms" class="px-8 py-4 bg-white text-[#084a79] rounded-2xl font-black text-lg hover:bg-blue-50 transition-all">
                  Αναλυτικός Οδηγός rTMS
                </a>
                <a href="/rtms/core/ti-einai" class="px-8 py-4 bg-transparent border border-white/20 text-white rounded-2xl font-bold text-lg hover:bg-white/5 transition-all">
                  Πώς Λειτουργεί;
                </a>
              </div>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div class="bg-white/10 backdrop-blur-md p-6 rounded-2xl border border-white/10">
                <div class="text-3xl mb-2">⚡</div>
                <div class="text-white font-bold mb-1 uppercase tracking-wider text-[10px]">Διαδικασία</div>
                <div class="text-blue-100 text-sm">3-20 λεπτά συνεδρία</div>
              </div>
              <div class="bg-white/10 backdrop-blur-md p-6 rounded-2xl border border-white/10 text-white">
                <div class="text-3xl mb-2">📉</div>
                <div class="text-white font-bold mb-1 uppercase tracking-wider text-[10px]">Αίσθηση</div>
                <div class="text-blue-100 text-sm">Ανώδυνη εφαρμογή</div>
              </div>
              <div class="bg-white/10 backdrop-blur-md p-6 rounded-2xl border border-white/10 text-white col-span-2">
                <div class="text-3xl mb-2">🏆</div>
                <div class="text-white font-bold mb-1 uppercase tracking-wider text-[10px]">Αποτέλεσμα</div>
                <div class="text-blue-100 text-sm">Υψηλά ποσοστά ύφεσης σε TRD</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 5: BIO / TRUST -->
    <section class="py-24 bg-[#f8fafc]">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row gap-16 items-center">
          <div class="w-full md:w-1/3">
            <div class="aspect-[3/4] rounded-3xl overflow-hidden shadow-2xl relative border-4 border-white bg-slate-100">
              <img src="/images/dr-gkikas-portrait.jpg" alt="Πασχάλης Γκίκας" width="800" height="1000" loading="lazy" decoding="async" class="w-full h-full object-cover object-top" />
            </div>
          </div>

          <div class="w-full md:w-2/3">
            <span class="text-[#084a79] font-bold tracking-widest text-xs uppercase mb-2 block">Πασχάλης Γκίκας</span>
            <h2 class="text-4xl md:text-5xl font-extrabold text-slate-900 mb-6">Ιατρική Αξιοπιστία & Εξειδίκευση</h2>
            <div class="prose prose-lg text-slate-600 font-light mb-10">
              <p>Ως Ψυχίατρος και Ιατρικός Διευθυντής του Smart CNS Center, εστιάζω στην εφαρμογή σύγχρονων εργαλείων νευροτροποποίησης και ψυχιατρικής ακριβείας. Η προσέγγισή μου βασίζεται στη διαρκή επιστημονική εξέλιξη και τον απόλυτο σεβασμό στη βιολογία του ασθενούς.</p>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 pt-8 border-t border-slate-200">
              <div class="bg-slate-50 p-4 rounded-xl border-l-4 border-l-[#d4af37] flex gap-3 items-center shadow-sm">
                <span class="text-2xl">🎓</span>
                <div class="flex flex-col gap-0.5"><span class="text-[10px] text-slate-400 uppercase font-bold tracking-widest">Πιστοποίηση</span><span class="text-sm font-bold text-slate-900">Harvard University</span></div>
              </div>
              <div class="bg-slate-50 p-4 rounded-xl border-l-4 border-l-[#d4af37] flex gap-3 items-center shadow-sm">
                <span class="text-2xl">🌐</span>
                <div class="flex flex-col gap-0.5"><span class="text-[10px] text-slate-400 uppercase font-bold tracking-widest">rTMS Training</span><span class="text-sm font-bold text-slate-900">Maastricht University Center</span></div>
              </div>
              <div class="bg-slate-50 p-4 rounded-xl border-l-4 border-l-[#d4af37] flex gap-3 items-center shadow-sm">
                <span class="text-2xl">🏥</span>
                <div class="flex flex-col gap-0.5"><span class="text-[10px] text-slate-400 uppercase font-bold tracking-widest">Ιατρικός Διευθυντής</span><span class="text-sm font-bold text-slate-900 line-clamp-1">Smart CNS Center, Αθήνα</span></div>
              </div>
            </div>
            <a href="/iatros" aria-label="Δείτε το πλήρες βιογραφικό του ιατρού Πασχάλη Γκίκα" class="inline-flex items-center gap-2 mt-12 font-black text-[#084a79] text-xl group">
              Πλήρες Βιογραφικό
              <span class="group-hover:translate-x-2 transition-transform duration-300">&rarr;</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 6: CONTACT & MAP -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-white rounded-3xl border border-slate-200 shadow-sm overflow-hidden flex flex-col lg:flex-row">
          <div class="lg:w-1/2 p-12 md:p-20">
            <h2 class="text-3xl md:text-5xl font-bold text-slate-900 mb-8">Ξεκινήστε την Πορεία προς την Ύφεση</h2>
            <p class="text-lg text-slate-600 mb-12 font-light leading-relaxed">
              Είμαστε εδώ για να απαντήσουμε σε κάθε ερώτηση και να σχεδιάσουμε μαζί το επόμενο βήμα στη θεραπεία σας.
            </p>
            <div class="space-y-6 mb-12">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-blue-50 text-blue-700 rounded-xl flex items-center justify-center">📞</div>
                <div>
                  <div class="text-xs text-slate-400 uppercase font-bold tracking-widest">Τηλέφωνο</div>
                  <div class="text-lg font-black text-slate-900">211 850 0016</div>
                </div>
              </div>
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-blue-50 text-blue-700 rounded-xl flex items-center justify-center">📍</div>
                <div>
                  <div class="text-xs text-slate-400 uppercase font-bold tracking-widest">Διεύθυνση</div>
                  <div class="text-lg font-black text-slate-900">Ξενοφώντος 15Α, Σύνταγμα, Αθήνα</div>
                </div>
              </div>
            </div>
            <a href="/epikoinonia" class="block text-center bg-[#084a79] text-white font-black py-5 rounded-2xl text-xl hover:bg-[#063557] transition-all">
              Κλείστε ραντεβού
            </a>
          </div>
          <div class="lg:w-1/2 bg-slate-100 min-h-[400px] relative">
            <iframe 
