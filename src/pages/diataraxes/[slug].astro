---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/UI/Header.astro';
import Footer from '../../components/UI/Footer.astro';

export async function getStaticPaths() {
  const disorders = await getCollection('disorders');
  return disorders.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={entry.data.title} description={entry.data.description}>
  <Header />
  <main class="pt-24 pb-16 bg-slate-50 min-h-screen">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="glass-card p-10 md:p-16 mt-8 border-t-4 border-t-amber-600">
        <span class="inline-block py-1 px-3 rounded-full bg-amber-100 text-amber-800 text-xs font-bold uppercase tracking-wider mb-4">Διαταραχες</span>
        <h1 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6">{entry.data.title}</h1>
        <p class="text-xl text-slate-600 mb-12 pb-8 border-b border-slate-200 leading-relaxed">{entry.data.description}</p>
        
        <div class="prose prose-lg prose-amber max-w-none text-slate-700
          prose-headings:text-slate-900 prose-headings:font-bold prose-h2:mt-12 prose-h2:mb-6
          prose-a:text-amber-700 hover:prose-a:text-amber-900 transition-colors
          prose-ul:my-6 prose-li:my-2">
          <Content />
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
