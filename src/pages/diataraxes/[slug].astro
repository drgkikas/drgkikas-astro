---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/UI/Header.astro';
import Footer from '../../components/UI/Footer.astro';

export async function getStaticPaths() {
  const disorders = await getCollection('disorders');
  return disorders.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout title={entry.data.title} description={entry.data.description}>
  <Header />
  <main class="pt-24 pb-16 bg-slate-50 min-h-screen">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="glass-card p-10 md:p-16 mt-8 border-t-4 border-t-amber-600">
        <div class="text-center mb-16 border-b border-slate-200 pb-12">
          <span class="inline-block py-1.5 px-4 rounded-full bg-amber-100 text-amber-800 text-xs font-black uppercase tracking-widest mb-6">Διαταραχες</span>
          <h1 class="text-4xl md:text-5xl font-bold text-slate-900 mb-8 leading-normal" set:html={entry.data.title}></h1>
          <p class="text-xl md:text-2xl text-slate-600 leading-relaxed max-w-3xl mx-auto">{entry.data.description}</p>
        </div>
        
        <div class="prose prose-lg md:prose-xl prose-amber max-w-none text-slate-700
          prose-p:mb-10 prose-p:leading-[1.9]
          prose-headings:text-slate-900 prose-headings:font-bold 
          prose-h2:mt-20 prose-h2:mb-8 prose-h2:border-b prose-h2:border-slate-100 prose-h2:pb-4
          prose-h3:mt-14 prose-h3:mb-6
          prose-a:font-bold prose-a:text-amber-900 prose-a:bg-amber-100 prose-a:px-2 prose-a:py-0.5 prose-a:rounded-lg prose-a:no-underline hover:prose-a:bg-amber-600 hover:prose-a:text-white prose-a:transition-colors
          prose-ul:my-10 prose-li:my-5 marker:text-amber-600">
          <Content />
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
