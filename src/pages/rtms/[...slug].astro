---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/UI/Header.astro';
import Footer from '../../components/UI/Footer.astro';

export async function getStaticPaths() {
  const rtms = await getCollection('rtms');
  return rtms.map(entry => ({
    params: { slug: entry.id },
    props: { entry, allPages: rtms },
  }));
}

const { entry, allPages } = Astro.props;
const { Content } = await render(entry);

// Group pages by category (folder)
const categories = {
  core: allPages.filter(p => p.id.startsWith('core/')).sort((a,b)=> (a.data.order||0) - (b.data.order||0)),
  endixeis: allPages.filter(p => p.id.startsWith('endixeis/')).sort((a,b)=> (a.data.order||0) - (b.data.order||0)),
  mechanisms: allPages.filter(p => p.id.startsWith('pos-leitourgei/')).sort((a,b)=> (a.data.order||0) - (b.data.order||0)),
};

const categoryNames = {
  core: "Βασικές Έννοιες",
  endixeis: "Ενδείξεις Θεραπείας",
  mechanisms: "Πώς Λειτουργεί"
};
---

<Layout title={`${entry.data.title} | rTMS | Dr. Γκίκας`} description={entry.data.description}>
  <Header />
  
  <div class="pt-24 pb-20 bg-slate-50 min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Breadcrumbs -->
      <nav class="text-sm text-slate-500 mb-8 mt-4">
        <ol class="list-none p-0 inline-flex flex-wrap items-center">
          <li class="flex items-center"><a href="/" class="hover:text-red-700 transition-colors">Αρχική</a><svg class="w-3 h-3 mx-2 opacity-50" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path></svg></li>
          <li class="flex items-center"><a href="/rtms/" class="hover:text-red-700 transition-colors">rTMS</a><svg class="w-3 h-3 mx-2 opacity-50" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path></svg></li>
          <li class="flex items-center"><span class="text-slate-800 font-medium">{entry.data.title}</span></li>
        </ol>
      </nav>

      <div class="flex flex-col lg:flex-row gap-10">
        <!-- Sidebar Navigation -->
        <aside class="w-full lg:w-1/4">
          <div class="sticky top-28 bg-white p-6 md:p-8 rounded-3xl border border-slate-100 shadow-sm">
            <h3 class="text-sm font-bold text-slate-900 mb-6 flex items-center gap-2">
              <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"></path></svg>
              Οδηγός rTMS
            </h3>
            
            <div class="space-y-8">
              {Object.entries(categories).map(([key, pages]) => (
                pages.length > 0 && (
                  <div>
                    <h4 class="text-xs uppercase font-bold text-slate-400 tracking-wider mb-4 border-b border-slate-100 pb-2">{categoryNames[key]}</h4>
                    <ul class="space-y-2">
                      {pages.map(p => {
                        const isActive = entry.id === p.id;
                        return (
                          <li>
                            <a 
                              href={`/rtms/${p.id}`} 
                              class={`block text-sm transition-all py-1.5 px-3 rounded-lg ${isActive ? 'bg-red-50 text-red-700 font-semibold' : 'text-slate-600 hover:text-slate-900 hover:bg-slate-50'}`}
                            >
                              {p.data.title}
                            </a>
                          </li>
                        );
                      })}
                    </ul>
                  </div>
                )
              ))}
            </div>

            <!-- CTA Widget in Sidebar -->
            <div class="mt-10 p-5 rounded-2xl bg-gradient-to-b from-red-50 to-white border border-red-100 text-center">
              <svg class="w-10 h-10 mx-auto text-red-600 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
              <h4 class="font-bold text-slate-900 mb-2">Κλείστε Ραντεβού</h4>
              <p class="text-xs text-slate-600 mb-4">Ενημερωθείτε για την καταλληλότητα της θεραπείας στο πρόβλημά σας.</p>
              <a href="/epikoinonia" class="block w-full text-center bg-red-700 text-white text-sm font-semibold py-2 rounded-xl hover:bg-red-800 transition-colors">Επικοινωνία</a>
            </div>

          </div>
        </aside>

        <!-- Main Content area -->
        <article class="w-full lg:w-3/4">
          <div class="bg-white rounded-3xl p-8 md:p-14 shadow-sm border border-slate-100 relative overflow-hidden">
            <!-- Top Red Line -->
            <div class="absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-red-500 to-red-800"></div>
            
            <header class="text-center mb-16 border-b border-slate-100 pb-12">
              <div class="flex items-center justify-center gap-2 text-xs font-bold uppercase tracking-wider mb-6">
                <span class="py-1 px-4 rounded-full bg-red-50 text-red-700 border border-red-100">Νευροτροποποιηση</span>
                <span class="py-1 px-4 rounded-full bg-slate-50 text-slate-500 border border-slate-200">2024</span>
              </div>
              <h1 class="text-4xl md:text-5xl font-bold text-slate-900 mb-8 leading-normal tracking-tight" set:html={entry.data.title}></h1>
              <p class="text-xl md:text-2xl text-slate-600 leading-relaxed max-w-3xl mx-auto font-light">{entry.data.description}</p>
            </header>
            
            <div class="prose prose-lg md:prose-xl max-w-none text-slate-700
              prose-p:mb-10 prose-p:leading-[1.9]
              prose-headings:text-slate-900 prose-headings:font-bold prose-headings:tracking-tight
              prose-h2:text-3xl prose-h2:mt-20 prose-h2:mb-8 prose-h2:border-b prose-h2:border-slate-100 prose-h2:pb-4
              prose-h3:text-2xl prose-h3:mt-14 prose-h3:mb-6
              prose-a:font-bold prose-a:text-red-900 prose-a:bg-red-100 prose-a:px-2 prose-a:py-0.5 prose-a:rounded-lg prose-a:no-underline hover:prose-a:bg-red-700 hover:prose-a:text-white prose-a:transition-colors
              prose-ul:my-10 prose-li:my-5 prose-strong:text-slate-900
              marker:text-red-500 
              prose-blockquote:border-l-4 prose-blockquote:border-red-500 prose-blockquote:bg-red-50/50 prose-blockquote:py-3 prose-blockquote:px-8 prose-blockquote:rounded-r-xl prose-blockquote:not-italic prose-blockquote:text-slate-800 prose-blockquote:font-medium
              prose-img:rounded-2xl prose-img:shadow-sm
              ">
              <Content />
            </div>
            
          </div>
        </article>
      </div>

    </div>
  </div>
  <Footer />
</Layout>
