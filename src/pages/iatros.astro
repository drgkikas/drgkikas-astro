---
import Layout from '../layouts/Layout.astro';
import Header from '../components/UI/Header.astro';
import Footer from '../components/UI/Footer.astro';

const schemaBundle = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["Person", "Physician"],
      "@id": "https://drgkikas.com/#physician",
      "name": "Πασχάλης Γκίκας",
      "jobTitle": "Ψυχίατρος - Ψυχοθεραπευτής",
      "worksFor": {
        "@id": "https://drgkikas.com/#clinic"
      },
      "alumniOf": [
        { "@type": "CollegeOrUniversity", "name": "Università di Bologna" },
        { "@type": "CollegeOrUniversity", "name": "Harvard University" },
        { "@type": "CollegeOrUniversity", "name": "Maastricht University" }
      ],
      "medicalSpecialty": "Psychiatry",
      "url": "https://drgkikas.com/iatros",
      "image": "https://drgkikas.com/images/iatros-profile.png",
      "telephone": "+302118500016",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Ξενοφώντος 15Α",
        "addressLocality": "Αθήνα",
        "postalCode": "105 57",
        "addressCountry": "GR"
      }
    }
  ]
});
---

<Layout schema={schemaBundle} title="Πασχάλης Γκίκας | Ψυχίατρος - Ψυχοθεραπευτής στην Αθήνα" description="Βιογραφικό του Πασχάλη Γκίκα, εξειδικευμένου ψυχιάτρου στη Νευροτροποποίηση (rTMS) και Φαρμακογονιδιωματική (PGx).">
  <Header />
  
  <main class="pt-20">
    <!-- Hero / Profile Section -->
    <section class="bg-slate-900 text-white py-20 lg:py-32 relative overflow-hidden">
      <!-- Background pattern -->
      <div class="absolute inset-0 opacity-10 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNjAiIGhlaWdodD0iNjAiIHZpZXdCb3g9IjAgMCA2MCA2MCIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj48ZyBmaWxsPSJub25lIiBmaWxsLXJ1bGU9ImV2ZW5vZGQiPjxwYXRoIGQ9Ik0zNiAzNHYtbGgtdmhwIiBzdHJva2U9IiNmZmYiIHN0cm9rZS13aWR0aD0iMiIvPjwvZz48L3N2Zz4=')]"></div>
      
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 flex flex-col md:flex-row items-center gap-12">
        <div class="w-48 h-48 md:w-64 md:h-64 flex-shrink-0 bg-slate-800 rounded-full border-4 border-slate-700 shadow-2xl overflow-hidden">
          <!-- Placeholder for Doctor's Photo. Assuming an image exists or will be added -->
          <img src="/images/iatros-profile.png" width="400" height="400" loading="lazy" decoding="async" alt="Πασχάλης Γκίκας Ψυχίατρος" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" />


        </div>
        
        <div class="text-center md:text-left">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-900/50 border border-blue-800 text-blue-300 text-xs font-semibold uppercase tracking-widest mb-4">
            Ιατρικός Διευθυντής Smart CNS Center
          </div>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white tracking-tight mb-4">
            Πασχάλης Γκίκας
          </h1>
          <p class="text-xl md:text-2xl text-slate-300 font-light mb-8 max-w-2xl">
            Ψυχίατρος – Ψυχοθεραπευτής με εξειδίκευση στη Νευροτροποποίηση (rTMS/tDCS) και τη Φαρμακογονιδιωματική Αξιολόγηση.
          </p>
          <div class="flex flex-wrap justify-center md:justify-start gap-4">
            <a href="#cv" class="btn-primary bg-blue-600 hover:bg-blue-500 text-white px-6 py-3 rounded-lg font-medium transition-colors">Πλήρες Βιογραφικό</a>
            <a href="#contact" class="btn-secondary bg-slate-800 hover:bg-slate-700 text-white px-6 py-3 rounded-lg font-medium transition-colors border border-slate-700">Επικοινωνία</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Page Content -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        
        <!-- Sticky Sidebar Navigation (Optional for long pages) -->
        <div class="hidden lg:block lg:col-span-3">
          <div class="sticky top-28 bg-white glass-card p-6 rounded-2xl shadow-sm border border-slate-100">
            <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-4">Περιεχόμενα Σελίδας</h4>
            <nav class="space-y-3">
              <a href="#cv" class="block text-slate-600 hover:text-blue-700 font-medium text-sm transition-colors">Βιογραφικό & Προφίλ</a>
              <a href="#experience" class="block text-slate-600 hover:text-blue-700 font-medium text-sm transition-colors">Κλινική Εμπειρία</a>
              <a href="#education" class="block text-slate-600 hover:text-blue-700 font-medium text-sm transition-colors">Εκπαίδευση & Πιστοποιήσεις</a>
              <a href="#media" class="block text-slate-600 hover:text-blue-700 font-medium text-sm transition-colors">Συνεργασίες & Εταιρείες</a>
            </nav>
            <div class="mt-8 pt-6 border-t border-slate-100">
              <a href="/epikoinonia" class="block w-full text-center bg-slate-100 hover:bg-slate-200 text-slate-800 font-medium px-4 py-2 rounded-lg text-sm transition-colors">Κλείστε Ραντεβού</a>
            </div>
          </div>
        </div>

        <!-- Main Content Column -->
        <div class="lg:col-span-9 space-y-16">
          
          <!-- SECTION 1: CV / Profil -->
          <section id="cv" class="scroll-mt-28">
            <div class="flex items-center gap-4 mb-8">
              <div class="w-12 h-12 rounded-xl bg-blue-100 flex items-center justify-center text-blue-700">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
              </div>
              <h2 class="text-3xl font-bold text-slate-900">Βιογραφικό Σημείωμα</h2>
            </div>
            
            <div class="prose prose-lg max-w-none text-slate-600 leading-relaxed">
              <p>Γεννήθηκα και μεγάλωσα στην Αθήνα. Σπούδασα Ιατρική στο <strong>Πανεπιστήμιο της Μπολόνια</strong> στην Ιταλία και ολοκλήρωσα την ειδικότητα της Ψυχιατρικής στο Ψυχιατρικό Νοσοκομείο Αττικής «Δαφνί», όπου εκπαιδεύτηκα στο Τμήμα Επειγόντων, στη <strong>Μονάδα Απεξάρτησης 18 ΑΝΩ</strong> και στο Κέντρο Ψυχικής Υγείας Περιστερίου.</p>
              
              <p>Παράλληλα με την ειδικότητα, εκπαιδεύτηκα στη Γνωσιακή-Συμπεριφορική Ψυχοθεραπεία (CBT) και στην Οικογενειακή Συστημική Ψυχοθεραπεία. Διαθέτω πιστοποίηση στις βασικές αρχές των νευροεπιστημών από το <strong>Harvard University</strong> και εξειδίκευση στον Διακρανιακό Μαγνητικό Ερεθισμό (<strong>rTMS</strong>) μέσα από εντατικά προγράμματα εκπαίδευσης του Πανεπιστημίου του <strong>Maastricht</strong>, στο Ηνωμένο Βασίλειο (Λονδίνο) και στις ΗΠΑ (San Francisco).</p>
              
              <h3 class="text-xl font-bold text-slate-900 mt-8 mb-4">Κλινικές Εξειδικεύσεις</h3>
              <p>Μεγάλο μέρος της κλινικής μου εμπειρίας αφορά τις <strong>διαταραχές διάθεσης</strong> — ιδιαίτερα τη Διπολική Διαταραχή και την Ανθεκτική Κατάθλιψη (TRD) — καθώς και αγχώδεις διαταραχές, διαταραχές ύπνου και ψυχοσωματικές εκδηλώσεις. Ασχολούμαι επίσης εκτενώς με τη θεραπευτική αντιμετώπιση διαταραχών χρήσης ουσιών, με ιδιαίτερη έμφαση στην απεξάρτηση από την κοκαΐνη.</p>
              
              <div class="bg-blue-50 border-l-4 border-blue-600 p-6 my-8 rounded-r-xl">
                <p class="mb-0 text-blue-900 font-medium">Στην κλινική μου πρακτική αξιοποιώ σύγχρονες μη επεμβατικές μεθόδους (rTMS / tDCS) και τη φαρμακογονιδιωματική αξιολόγηση (PGx), με στόχο την ασφαλή εξατομίκευση της θεραπείας βάσει του γενετικού προφίλ κάθε ασθενούς.</p>
              </div>
            </div>
          </section>

          <!-- SECTION 2: Experience Timeline -->
          <section id="experience" class="scroll-mt-28">
            <div class="flex items-center gap-4 mb-8">
              <div class="w-12 h-12 rounded-xl bg-teal-100 flex items-center justify-center text-teal-700">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              </div>
              <h2 class="text-3xl font-bold text-slate-900">Κλινική Εμπειρία</h2>
            </div>

            <div class="space-y-8 relative before:absolute before:inset-y-0 before:left-[19px] before:w-[2px] before:bg-slate-200 ml-2">
              
              <!-- Smart CNS -->
              <div class="relative pl-12">
                <div class="absolute w-10 h-10 bg-white rounded-full border-4 border-blue-600 left-[-1px] top-0 flex items-center justify-center shadow-sm">
                  <div class="w-3 h-3 bg-blue-600 rounded-full"></div>
                </div>
                <div class="glass-card bg-white p-6 rounded-2xl shadow-sm border border-slate-100 hover:border-blue-200 transition-colors">
                  <h3 class="text-lg font-bold text-slate-900">Συνιδρυτής &amp; Ιατρικός Διευθυντής</h3>
                  <p class="text-slate-600 font-medium mb-3">Smart CNS Center, Αθήνα</p>
                  <p class="text-sm text-slate-500">Εξειδικευμένο κέντρο Ψυχιατρικής με έμφαση στη Νευροτροποποίηση (rTMS, tDCS), τη Φαρμακογονιδιωματική, την Ψυχοθεραπεία και τη Φωτοθεραπεία.</p>
                </div>
              </div>

              <!-- Private Practice -->
              <div class="relative pl-12 flex flex-col justify-center mt-6">
                <div class="absolute w-4 h-4 bg-slate-300 rounded-full left-[12px] top-2 border-2 border-white"></div>
                <div>
                  <span class="text-slate-800 font-medium block">Ψυχίατρος, Ιδιωτικό Ιατρείο</span>
                  <span class="text-slate-500 text-sm">Αθήνα</span>
                </div>
              </div>

              <!-- NGOs (Active) -->
              <div class="relative pl-12">
                <div class="absolute w-4 h-4 bg-slate-300 rounded-full left-[12px] top-2 border-2 border-white"></div>
                <div class="pl-0">
                  <h4 class="text-md font-bold text-slate-900 mb-2">Κοινοτική Ψυχιατρική &amp; Επιστημονική Ευθύνη (ΜΚΟ)</h4>
                  <ul class="space-y-3 text-sm text-slate-600 pl-4 list-disc marker:text-slate-300">
                    <li><strong class="text-slate-700">ΜΚΟ ΞΕΝΙΟΣ ΖΕΥΣ</strong>: Επιστημονικός Συνεργάτης προστατευόμενων διαμερισμάτων.</li>
                    <li><strong class="text-slate-700">ΜΚΟ ΑΛΘΑΙΑ</strong>: Επιστημονικός Υπεύθυνος Στεγαστικών Δομών και Προστατευόμενων Διαμερισμάτων.</li>
                    <li><strong class="text-slate-700">ΜΚΟ ΙΑΣΙΣ</strong>: Επιστημονικός Υπεύθυνος / Ψυχίατρος σε δομές (π.χ. Άγιος Μάρκος).</li>
                    <li><strong class="text-slate-700">ΜΚΟ ΕΠΑΨΥ</strong>: Επιστημονικός Συνεργάτης δομών.</li>
                  </ul>
                  <p class="text-xs text-slate-400 mt-2 italic">Η δραστηριότητά μου στον χώρο της κοινοτικής ψυχιατρικής εστιάζει στη μακροχρόνια παρακολούθηση ασθενών με σοβαρές ψυχικές διαταραχές, στη λειτουργική αποκατάσταση και ενσωμάτωσή τους.</p>
                </div>
              </div>

              <!-- Hospital History -->
              <div class="relative pl-12 flex flex-col pt-4">
                <div class="absolute w-4 h-4 bg-slate-200 rounded-full left-[12px] top-5 border-2 border-white"></div>
                <h4 class="text-sm font-bold text-slate-500 uppercase tracking-wide mb-4">Νοσοκομειακή Εμπειρία</h4>
                <ul class="space-y-4 text-sm text-slate-600 pl-4 list-disc marker:text-slate-300">
                  <li>Ψυχιατρικό Νοσοκομείο Αττικής Δαφνί</li>
                  <li>Γενικό Νοσοκομείο ΚΑΤ</li>
                  <li>1ο Θεραπευτήριο ΙΚΑ Μελισσίων</li>
                  <li>Γενικό Νοσοκομείο Σύρου «Βαρδάκειο &amp; Πρώιο</li>
                </ul>
              </div>
            </div>
          </section>

          <!-- SECTION 3: Education & Training -->
          <section id="education" class="scroll-mt-28">
            <div class="flex items-center gap-4 mb-8">
              <div class="w-12 h-12 rounded-xl bg-orange-100 flex items-center justify-center text-orange-700">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14v7M5 9.42V14a7 7 0 0014 0V9.42"></path></svg>
              </div>
              <h2 class="text-3xl font-bold text-slate-900">Εκπαίδευση & Πιστοποιήσεις</h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              
              <div class="bg-white rounded-2xl border border-slate-200 p-8 shadow-sm">
                <h3 class="text-lg font-bold text-slate-900 mb-6 flex items-center gap-2">
                  <span class="w-2 h-2 rounded-full bg-orange-500"></span>
                  Νευροεπιστήμες & rTMS
                </h3>
                <ul class="space-y-5 text-sm">
                  <li class="pl-4 border-l-2 border-slate-100 pb-2">
                    <strong class="text-slate-800 block">Advanced TMS Update Course</strong>
                    <span class="text-slate-600 block">Maastricht Brain Imaging Center, Ολλανδία</span>
                  </li>
                  <li class="pl-4 border-l-2 border-slate-100 pb-2">
                    <strong class="text-slate-800 block">Fundamentals of Neuroscience</strong>
                    <span class="text-slate-600 block">Harvard University, Η.Π.Α.</span>
                  </li>
                  <li class="pl-4 border-l-2 border-slate-100 pb-2">
                    <strong class="text-slate-800 block">TMS Clinical Applications</strong>
                    <span class="text-slate-600 block">APA Annual Meeting, San Francisco, Η.Π.Α.</span>
                  </li>
                  <li class="pl-4 border-l-2 border-slate-100 pb-2">
                    <strong class="text-slate-800 block">Clinical TMS Certification Course</strong>
                    <span class="text-slate-600 block">Maastricht University, Διεξαγωγή στο Λονδίνο, Η.Β.</span>
                  </li>
                </ul>
              </div>

              <div class="bg-white rounded-2xl border border-slate-200 p-8 shadow-sm">
                <h3 class="text-lg font-bold text-slate-900 mb-6 flex items-center gap-2">
                  <span class="w-2 h-2 rounded-full bg-slate-400"></span>
                  Ψυχοθεραπεία & Ακαδημαϊκά
                </h3>
                <ul class="space-y-5 text-sm">
                  <li class="pl-4 border-l-2 border-slate-100 pb-2">
                    <strong class="text-slate-800 block">Λήψη Ειδικότητας Ψυχιατρικής (Board Certification)</strong>
                  </li>
                  <li class="pl-4 border-l-2 border-slate-100 pb-2">
                    <strong class="text-slate-800 block">Πτυχίο Ιατρικής (M.D.)</strong>
                    <span class="text-slate-600 block">Università di Bologna, Ιταλία</span>
                  </li>
                  <li class="pl-4 border-l-2 border-slate-100 pb-2">
                    <strong class="text-slate-800 block">Οικογενειακή Συστημική Ψυχοθεραπεία</strong>
                    <span class="text-slate-600 block">Ψυχιατρικό Νοσοκομείο Αττικής</span>
                  </li>
                  <li class="pl-4 border-l-2 border-slate-100 pb-2">
                    <strong class="text-slate-800 block">Γνωσιακή Συμπεριφορική Ψυχοθεραπεία (CBT)</strong>
                    <span class="text-slate-600 block">Κέντρο Εφαρμοσμένης Ψυχοθεραπείας, Αθήνα</span>
                  </li>
                </ul>
              </div>
            </div>
          </section>

          <!-- SECTION 4: Media, Societies & Accreditations -->
          <section id="media" class="scroll-mt-28 mb-16">
            <div class="flex items-center gap-4 mb-8">
              <div class="w-12 h-12 rounded-xl bg-purple-100 flex items-center justify-center text-purple-700">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
              </div>
              <h2 class="text-3xl font-bold text-slate-900">Συνεργασίες & Επιστημονικό Έργο</h2>
            </div>

            <div class="glass-card bg-slate-900 text-white rounded-2xl p-8 md:p-12 shadow-lg">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                
                <div>
                  <h3 class="text-lg font-bold text-blue-300 mb-6 uppercase tracking-wider text-sm flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                    Επιστημονικές Εταιρείες
                  </h3>
                  <ul class="space-y-4 text-slate-300 text-sm">
                    <li class="flex gap-3">
                      <span class="text-blue-500 mt-1">✓</span>
                      <span>Ταμίας της <strong>Ένωσης Επαγγελματιών Ψυχιάτρων Ελλάδος (ΕΝ.Ε.Ψ.Ε.)</strong> (για 2 θητείες)</span>
                    </li>
                    <li class="flex gap-3">
                      <span class="text-blue-500 mt-1">✓</span>
                      <span>Γραμματέας του Κλάδου Ιδιωτών της <strong>Ελληνικής Ψυχιατρικής Εταιρείας (ΕΨΕ)</strong> (για 2 θητείες)</span>
                    </li>
                    <li class="flex gap-3">
                      <span class="text-blue-500 mt-1">✓</span>
                      <span>Μέλος της <strong>American Psychiatric Association (APA)</strong></span>
                    </li>
                    <li class="flex gap-3">
                      <span class="text-blue-500 mt-1">✓</span>
                      <span>Μέλος της <strong>Hellenic-American Psychiatric Association (HAPA)</strong></span>
                    </li>
                    <li class="flex gap-3">
                      <span class="text-blue-500 mt-1">✓</span>
                      <span>Μέλος της <strong>Ελληνικής Ψυχιατροδικαστικής Εταιρείας</strong> και της Επιτροπής Ψυχικής Υγείας του <strong>ΙΣΑ</strong>.</span>
                    </li>
                  </ul>
                </div>

                <div>
                   <h3 class="text-lg font-bold text-purple-300 mb-6 uppercase tracking-wider text-sm flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                    Εκπαιδευτικό & Κοινωνικό Έργο
                  </h3>
                   <ul class="space-y-4 text-slate-300 text-sm">
                    <li class="flex items-start gap-3">
                      <span class="w-1.5 h-1.5 rounded-full bg-purple-400 mt-2 shrink-0"></span>
                      <span>Έχω διδάξει Γνωσιακή-Συμπεριφορική Ψυχοθεραπεία (CBT) σε πιστοποιημένο Κέντρο Δια Βίου Μάθησης (2014-2016).</span>
                    </li>
                    <li class="flex items-start gap-3">
