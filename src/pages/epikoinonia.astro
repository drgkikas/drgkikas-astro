---
import Layout from '../layouts/Layout.astro';
import Header from '../components/UI/Header.astro';
import Footer from '../components/UI/Footer.astro';

const schemaBundle = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Physician",
      "@id": "https://drgkikas.com/#physician"
    },
    {
      "@type": "MedicalClinic",
      "@id": "https://drgkikas.com/#clinic",
      "name": "Ιδιωτικό Ιατρείο Πασχάλης Γκίκας",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Ξενοφώντος 15Α",
        "addressLocality": "Αθήνα",
        "postalCode": "105 57",
        "addressCountry": "GR"
      },
      "telephone": "+302118500016",
      "email": "contact@drgkikas.com",
      "contactPoint": {
          "@type": "ContactPoint",
          "telephone": "+302118500016",
          "contactType": "Customer Service"
      }
    }
  ]
});

// SSR Handle POST submission
if (Astro.request.method === 'POST') {
  try {
    const body = await Astro.request.json();
    const { firstname, lastname, email, phone, message } = body;

    // Astro 6 + Cloudflare environment access (Dynamic import to avoid build errors)
    const { env } = await import('cloudflare:workers' as any);
    const resendKey = (env as any).RESEND_API_KEY;
    
    if (!resendKey) throw new Error('Key missing from environment');

    const emailHtml = `<p><strong>Από:</strong> ${firstname} ${lastname}</p><p><strong>Email:</strong> ${email}</p><p><strong>Τηλ:</strong> ${phone}</p><hr/><p>${message}</p>`;

    const resendRes = await fetch('https://api.resend.com/emails', {
      method: 'POST',
      headers: { 'Authorization': `Bearer ${resendKey}`, 'Content-Type': 'application/json' },
      body: JSON.stringify({
        from: 'Δρ. Γκίκας <noreply@drgkikas.com>',
        to: 'contact@drgkikas.com',
        subject: `Μήνυμα από ${firstname} ${lastname}`,
        html: emailHtml,
        reply_to: email,
      }),
    });

    if (!resendRes.ok) throw new Error('Resend failed');

    return new Response(JSON.stringify({ success: true }), { status: 200 });
  } catch (err: any) {
    return new Response(JSON.stringify({ error: err.message }), { status: 500 });
  }
}
---

<Layout schema={schemaBundle} 
  title="Επικοινωνία | Πασχάλης Γκίκας | Ψυχίατρος Αθήνα"
  description="Επικοινωνήστε με τον ψυχίατρο Πασχάλη Γκίκα για να κλείσετε το ραντεβού σας. Ιατρείο στο κέντρο της Αθήνας (Σύνταγμα)."
>
  <Header />

  <main class="pt-32 pb-24 bg-slate-50 min-h-screen relative overflow-hidden">
    <!-- Background element -->
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-blue-900 rounded-full blur-[120px] opacity-10 pointer-events-none translate-x-1/2 -translate-y-1/2"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      
      <div class="text-center md:text-left mb-16">
        <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900 mb-6 tracking-tight">Επικοινωνία & Ραντεβού</h1>
        <p class="text-xl text-slate-600 max-w-2xl leading-relaxed">
          Προγραμματίστε το ραντεβού σας. Μπορείτε να επικοινωνήσετε τηλεφωνικά, μέσω email ή συμπληρώνοντας τη φόρμα επικοινωνίας.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        
        <!-- Contact Info & Cards (Left Column) -->
        <div class="lg:col-span-5 space-y-8">
          
          <!-- Unified Scan-Friendly NAP Card -->
          <div class="bg-white rounded-3xl shadow-lg border border-slate-200 overflow-hidden">
            <div class="bg-slate-900 text-white p-6">
              <h3 class="text-xl font-bold uppercase tracking-widest text-[#d4af37]">Ιδιωτικο Ιατρειο</h3>
              <p class="text-slate-300 text-sm mt-1">Πασχάλης Γκίκας, Ψυχίατρος - Ψυχοθεραπευτής</p>
            </div>
            
            <div class="p-8 space-y-8">
              <!-- Location -->
              <div class="flex items-start gap-4">
                <div class="mt-1 w-10 h-10 rounded-full bg-slate-50 flex items-center justify-center text-xl shrink-0 shadow-sm border border-slate-100">📍</div>
                <div>
                  <div class="text-xs font-bold text-slate-400 tracking-widest uppercase mb-1">Διευθυνση</div>
                  <div class="text-slate-900 font-bold text-lg">Ξενοφώντος 15Α, Τ.Κ. 105 57</div>
                  <div class="text-slate-500 font-medium mb-3">Σύνταγμα, Αθήνα</div>
                  <a href="https://maps.app.goo.gl/ygEdMyCULtaLUGNCA" target="_blank" rel="noopener noreferrer" class="text-sm font-bold text-[#084a79] hover:text-blue-800 transition-colors inline-flex items-center gap-1 group">
                    Οδηγίες Google Maps <span class="group-hover:translate-x-1 transition-transform">&rarr;</span>
                  </a>
                </div>
              </div>
              
              <hr class="border-slate-100" />
              
              <!-- Phones -->
              <div class="flex flex-col gap-5">
                <div class="flex items-center gap-4">
                  <div class="w-10 h-10 rounded-full bg-slate-50 flex items-center justify-center text-xl shrink-0 shadow-sm border border-slate-100">📞</div>
                  <div class="flex-1">
                    <div class="text-xs font-bold text-slate-400 tracking-widest uppercase mb-0.5">Σταθερο</div>
                    <a href="tel:2118500016" class="text-slate-900 font-bold text-xl hover:text-[#084a79] transition-colors block">211 850 0016</a>
                  </div>
                </div>
                <div class="flex items-center gap-4">
                  <div class="w-10 h-10 rounded-full bg-slate-50 flex items-center justify-center text-xl shrink-0 shadow-sm border border-slate-100">📱</div>
                  <div class="flex-1">
                     <div class="text-xs font-bold text-slate-400 tracking-widest uppercase mb-0.5">Κινητο</div>
                     <a href="tel:6940308700" class="text-slate-900 font-bold text-xl hover:text-[#084a79] transition-colors block">6940 308 700</a>
                  </div>
                </div>
              </div>

              <hr class="border-slate-100" />

              <!-- Email -->
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-full bg-slate-50 flex items-center justify-center text-xl shrink-0 shadow-sm border border-slate-100">✉️</div>
                <div class="flex-1">
                  <div class="text-xs font-bold text-slate-400 tracking-widest uppercase mb-0.5">E-mail</div>
                  <a href="mailto:contact@drgkikas.com" class="text-slate-900 font-bold text-lg hover:text-[#084a79] transition-colors">contact@drgkikas.com</a>
                </div>
              </div>
            </div>
            
            <!-- Map Embed directly inside NAP -->
            <div class="h-[250px] w-full bg-slate-100 border-t border-slate-200">
               <iframe 
                src="https://maps.google.com/maps?q=%CE%A8%CF%85%CF%87%CE%AF%CE%B1%CF%84%CF%81%CE%BF%CF%82+-+%CE%A8%CF%85%CF%87%CE%BF%CE%B8%CE%B5%CF%81%CE%B1%CF%80%CE%B5%CF%85%CF%84%CE%AE%CF%82,+%CE%A0%CE%B1%CF%83%CF%87%CE%AC%CE%BB%CE%B7%CF%82+%CE%93%CE%BA%CE%AF%CE%BA%CE%B1%CF%82&t=&z=16&ie=UTF8&iwloc=&output=embed" 
                width="100%" 
                height="100%" 
                style="border:0;" 
                allowfullscreen="" 
                loading="lazy" 
                class="w-full h-full grayscale-[20%] contrast-[1.1]"
              ></iframe>
            </div>
          </div>

          <div class="bg-blue-50/70 p-6 rounded-2xl border border-blue-100 flex items-start gap-4">
             <div class="mt-1 w-8 h-8 rounded-full bg-blue-100 text-blue-800 flex items-center justify-center text-sm shrink-0">ℹ</div>
             <div>
              <h4 class="text-slate-800 font-bold mb-1">rTMS & Smart CNS Center</h4>
              <p class="text-sm text-slate-600 leading-relaxed">
                Οι συνεδρίες Νευροτροποποίησης διεξάγονται αποκλειστικά στις εξειδικευμένες εγκαταστάσεις του Smart CNS Center. Επικοινωνήστε μαζί μας για τον προγραμματισμό και τυχόν απορίες.
              </p>
             </div>
          </div>

        </div>

        <!-- Form (Right Column) -->
        <div class="lg:col-span-7">
          <div class="bg-white p-8 md:p-12 rounded-3xl shadow-lg border border-slate-100 h-full">
            <h3 class="text-2xl font-bold text-slate-900 mb-2">Φόρμα Επικοινωνίας</h3>
            <p class="text-slate-500 mb-10 text-sm" id="form-desc">Τα πεδία με αστερίσκο (*) είναι υποχρεωτικά.</p>

            <!-- Success Message Container (Hidden by default) -->
            <div id="success-message" class="hidden">
              <div class="flex flex-col items-center justify-center py-12 text-center">
                <div class="w-20 h-20 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center text-3xl mb-6 shadow-sm border border-emerald-200">
                  ✓
                </div>
                <h4 class="text-2xl font-bold text-slate-900 mb-4">Επιτυχής Αποστολή!</h4>
                <p class="text-slate-600 mb-8 max-w-sm">
                  Ευχαριστούμε για την επικοινωνία. Το μήνυμά σας παραλήφθηκε και θα επικοινωνήσουμε μαζί σας το συντομότερο δυνατό.
                </p>
                <button onclick="window.location.reload()" class="text-[#084a79] font-bold hover:underline">
                  Επιστροφή στη φόρμα
                </button>
              </div>
            </div>

            <!-- Error Message (Hidden by default) -->
            <div id="error-message" class="hidden mb-8 bg-red-50 border border-red-100 text-red-700 px-6 py-4 rounded-xl text-sm font-medium">
               <span id="error-text">Κάτι πήγε στραβά.</span> 
               Παρακαλούμε προσπαθήστε ξανά ή καλέστε μας στο <a href="tel:2118500016" class="underline">211 850 0016</a>.
            </div>

            <form id="contact-form" class="space-y-6">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label for="firstname" class="block text-sm font-medium text-slate-700 mb-2">Όνομα *</label>
                  <input type="text" id="firstname" name="firstname" required class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-[#084a79] focus:border-[#084a79] outline-none transition-shadow" placeholder="π.χ. Γιάννης">
                </div>
                <div>
                  <label for="lastname" class="block text-sm font-medium text-slate-700 mb-2">Επώνυμο *</label>
                  <input type="text" id="lastname" name="lastname" required class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-[#084a79] focus:border-[#084a79] outline-none transition-shadow" placeholder="π.χ. Παπαδόπουλος">
                </div>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label for="email" class="block text-sm font-medium text-slate-700 mb-2">E-mail *</label>
                  <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-[#084a79] focus:border-[#084a79] outline-none transition-shadow" placeholder="email@example.com">
                </div>
                <div>
                  <label for="phone" class="block text-sm font-medium text-slate-700 mb-2">Τηλέφωνο επικοινωνίας *</label>
                  <input type="tel" id="phone" name="phone" required class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-[#084a79] focus:border-[#084a79] outline-none transition-shadow" placeholder="π.χ. 6900000000">
                </div>
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-slate-700 mb-2">Το μήνυμά σας *</label>
                <textarea id="message" name="message" rows="4" required class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-[#084a79] focus:border-[#084a79] outline-none transition-shadow resize-none" placeholder="Πώς μπορούμε να σας βοηθήσουμε;"></textarea>
              </div>

              <div class="flex items-start">
                <div class="flex items-center h-5">
                  <input id="privacy" name="privacy" type="checkbox" required class="w-4 h-4 border border-slate-300 rounded bg-white text-[#084a79] focus:ring-3 focus:ring-blue-300">
                </div>
                <label for="privacy" class="ml-3 text-sm text-slate-600">
                  Αποδέχομαι τους <a href="/privacy-policy" class="text-[#084a79] hover:underline font-bold">Όρους Χρήσης και την Πολιτική Απορρήτου *</a>.
                </label>
              </div>

              <button type="submit" class="w-full btn-primary bg-[#084a79] hover:bg-[#063354] text-white py-4 rounded-xl text-lg font-bold mt-4 shadow-lg shadow-[#084a79]/30 transition-all hover:-translate-y-1">
                Αποστολή Μηνύματος
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('success-message');
  const errorMsg = document.getElementById('error-message');
  const formDesc = document.getElementById('form-desc');
  const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement;

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      // Reset states
      errorMsg?.classList.add('hidden');
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.innerHTML = `
          <svg class="animate-spin h-5 w-5 mr-3 inline-block" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          Αποστολή...
        `;
      }

      try {
        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());
        
        const response = await fetch('/epikoinonia', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(data)
        });

        const result = await response.json();

        if (response.ok) {
          form.classList.add('hidden');
          formDesc?.classList.add('hidden');
          successMsg?.classList.remove('hidden');
          window.scrollTo({ top: form.offsetTop - 100, behavior: 'smooth' });
        } else {
          throw new Error(result.error || 'Submission failed');
        }
      } catch (err: any) {
        console.error('Submit error:', err);
        const errorText = document.getElementById('error-text');
        if (errorText) errorText.textContent = err.message + '. ';
        errorMsg?.classList.remove('hidden');
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Αποστολή Μηνύματος';
        }
      }
    });
  }
</script>
