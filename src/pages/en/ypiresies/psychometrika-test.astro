---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/UI/Header.astro';
import Footer from '../../../components/UI/Footer.astro';

const title = "Psychometric tests & clinical assessment";
const description = "Validated psychometric tools for measuring depression, anxiety, stress and other conditions — as part of clinical assessment. Athens & online.";
const canonicalURL = "https://drgkikas.com/en/ypiresies/psychometrika-test";

const schemaBundle = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "MedicalProcedure",
      "name": title,
      "description": description,
      "url": canonicalURL
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://drgkikas.com/en" },
        { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://drgkikas.com/en/ypiresies" },
        { "@type": "ListItem", "position": 3, "name": title, "item": canonicalURL }
      ]
    }
  ]
});
---

<Layout title={title} description={description} schema={schemaBundle}>
  <Header />
  <main class="pt-24 pb-16 bg-slate-50 min-h-screen">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Breadcrumbs UI -->
      <nav class="text-sm text-slate-500 mb-8 mt-4">
        <ol class="list-none p-0 inline-flex flex-wrap items-center">
          <li class="flex items-center"><a href="/en" class="hover:text-blue-700 transition-colors">Home</a><svg class="w-3 h-3 mx-2 opacity-50" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path></svg></li>
          <li class="flex items-center"><a href="/en/ypiresies/" class="hover:text-blue-700 transition-colors">Services</a><svg class="w-3 h-3 mx-2 opacity-50" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path></svg></li>
          <li class="flex items-center"><span class="text-slate-800 font-medium">{title}</span></li>
        </ol>
      </nav>

      <div class="glass-card p-10 md:p-16">
        <div class="text-center mb-16 border-b border-slate-200 pb-12">
          <h1 class="text-4xl md:text-5xl font-bold text-blue-900 mb-8 leading-normal">{title}</h1>
          <p class="text-xl md:text-2xl text-slate-600 leading-relaxed max-w-3xl mx-auto">{description}</p>
        </div>
        
        <div class="prose prose-lg md:prose-xl prose-blue max-w-none text-slate-700
          prose-p:mb-10 prose-p:leading-[1.9]
          prose-headings:text-blue-900 prose-headings:font-bold 
          prose-h2:mt-20 prose-h2:mb-8 prose-h2:border-b prose-h2:border-slate-100 prose-h2:pb-4
          prose-h3:mt-14 prose-h3:mb-6
          prose-a:font-bold prose-a:text-blue-900 prose-a:bg-blue-100 prose-a:px-2 prose-a:py-0.5 prose-a:rounded-lg prose-a:no-underline hover:prose-a:bg-blue-700 hover:prose-a:text-white prose-a:transition-colors
          prose-ul:my-10 prose-li:my-5 marker:text-blue-500">
          
          <p class="font-bold">Mental health can be measured. “I feel better” is not enough — data are needed.</p>

          <h2>What are psychometric tools?</h2>
          <p>Psychometric tools are validated, scientifically tested questionnaires that quantitatively measure symptoms of mental disorders. They are used internationally both for diagnostic purposes and for monitoring treatment response. The difference from a “normal conversation” is that the results are objective, comparable and trackable over time. We know how much something improved — and whether it worsened.</p>

          <h2>Psychometric tools used in the clinic</h2>
          <ul>
            <li><strong>PHQ-9</strong> — screening and monitoring of depression</li>
            <li><strong>GAD-7</strong> — screening and measurement of generalized anxiety</li>
            <li><strong>BAI</strong> — Beck Anxiety Inventory</li>
            <li><strong>DASS-21</strong> — simultaneous measurement of depression, anxiety and stress</li>
            <li><strong>PTSD Checklist</strong> — screening for post-traumatic stress</li>
            <li><strong>EAT-26</strong> — screening for eating disorders</li>
            <li><strong>Adult ADHD Self-Report Scale</strong> — adult ADHD assessment</li>
            <li><strong>WHOQOL-BREF</strong> — quality-of-life measurement</li>
          </ul>
          <p>For OCD, psychotic disorders, autism and sleep disorders, specialized clinical scales are used by the physician, selected according to diagnosis and assessment goal.</p>

          <h2>How they are used in clinical practice</h2>
          <p>Psychometric tools do not replace clinical judgment; they complement it. In the clinic, I use them:</p>
          <ul>
            <li>During the initial assessment, to grade symptom severity and define baseline</li>
            <li>During treatment, at regular intervals, to monitor response</li>
            <li>In clinical decision-making, such as medication adjustment, integration of rTMS or psychotherapy, or treatment completion</li>
            <li>In issuing medical reports, as objective documentation of the clinical picture</li>
          </ul>

          <h2>Can I complete a psychometric test online?</h2>
          <p>Some psychometric tools can be completed digitally before the visit, saving time and providing an initial picture before our meeting. Some clinical tools require administration by a trained clinician and are not self-administered.</p>

          <div class="mt-20 pt-12 border-t border-slate-200">
            <h2 class="text-2xl font-bold text-blue-900 mb-8">FAQ</h2>
            <div class="space-y-8">
              <div>
                <h3 class="text-lg font-bold text-slate-900 mb-2">Do psychometric tests “stigmatize”?</h3>
                <p class="text-slate-600">No. They are medical measurement tools, comparable to measuring blood pressure or glucose. Their use reflects scientific seriousness, not severity of illness.</p>
              </div>
              <div>
                <h3 class="text-lg font-bold text-slate-900 mb-2">Can I request a psychometric assessment without being a patient?</h3>
                <p class="text-slate-600">Yes. It is available as a standalone assessment for those who want an objective check of their mental state, especially during periods of intense stress or change.</p>
              </div>
              <div>
                <h3 class="text-lg font-bold text-slate-900 mb-2">How long does a psychometric assessment take?</h3>
                <p class="text-slate-600">Depending on the number of tools, 20–45 minutes. It is usually integrated into the clinical session.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Internal Links for SEO -->
        <div class="mt-20 pt-12 border-t border-slate-200">
          <h2 class="text-2xl font-bold text-blue-900 mb-8">Related Services</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <a href="/en/ypiresies/psychiatriki-parakolouthisi/" class="p-6 bg-blue-50 rounded-2xl border border-blue-100 hover:border-blue-300 transition-all font-bold text-blue-900">Psychiatric follow-up &rarr;</a>
            <a href="/en/ypiresies/adhd-evaluation/" class="p-6 bg-blue-50 rounded-2xl border border-blue-100 hover:border-blue-300 transition-all font-bold text-blue-900">ADHD assessment &rarr;</a>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
