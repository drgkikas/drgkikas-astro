---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/UI/Header.astro';
import Footer from '../../../components/UI/Footer.astro';

const title = "Psychiatric medical reports & certificates";
const description = "Issuing psychiatric medical reports and certificates for work, legal use, disability assessment, firearm licensing and other administrative purposes. Athens.";
const canonicalURL = "https://drgkikas.com/en/ypiresies/gnomateyseis";

const schemaBundle = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "MedicalProcedure",
      "name": title,
      "description": description,
      "url": canonicalURL
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://drgkikas.com/en" },
        { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://drgkikas.com/en/ypiresies" },
        { "@type": "ListItem", "position": 3, "name": title, "item": canonicalURL }
      ]
    }
  ]
});
---

<Layout title={title} description={description} schema={schemaBundle}>
  <Header />
  <main class="pt-24 pb-16 bg-slate-50 min-h-screen">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Breadcrumbs UI -->
      <nav class="text-sm text-slate-500 mb-8 mt-4">
        <ol class="list-none p-0 inline-flex flex-wrap items-center">
          <li class="flex items-center"><a href="/en" class="hover:text-blue-700 transition-colors">Home</a><svg class="w-3 h-3 mx-2 opacity-50" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path></svg></li>
          <li class="flex items-center"><a href="/en/ypiresies/" class="hover:text-blue-700 transition-colors">Services</a><svg class="w-3 h-3 mx-2 opacity-50" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path></svg></li>
          <li class="flex items-center"><span class="text-slate-800 font-medium">{title}</span></li>
        </ol>
      </nav>

      <div class="glass-card p-10 md:p-16">
        <div class="text-center mb-16 border-b border-slate-200 pb-12">
          <h1 class="text-4xl md:text-5xl font-bold text-blue-900 mb-8 leading-normal">{title}</h1>
          <p class="text-xl md:text-2xl text-slate-600 leading-relaxed max-w-3xl mx-auto">{description}</p>
        </div>
        
        <div class="prose prose-lg md:prose-xl prose-blue max-w-none text-slate-700
          prose-p:mb-10 prose-p:leading-[1.9]
          prose-headings:text-blue-900 prose-headings:font-bold 
          prose-h2:mt-20 prose-h2:mb-8 prose-h2:border-b prose-h2:border-slate-100 prose-h2:pb-4
          prose-h3:mt-14 prose-h3:mb-6
          prose-a:font-bold prose-a:text-blue-900 prose-a:bg-blue-100 prose-a:px-2 prose-a:py-0.5 prose-a:rounded-lg prose-a:no-underline hover:prose-a:bg-blue-700 hover:prose-a:text-white prose-a:transition-colors
          prose-ul:my-10 prose-li:my-5 marker:text-blue-500">
          
          <p class="font-bold">Documented, objective medical opinion based on clinical assessment — for administrative or legal needs.</p>

          <h2>What is a psychiatric medical report?</h2>
          <p>A psychiatric medical report is an official medical document that certifies a person’s mental state based on clinical interview, psychometric assessment and, when necessary, review of medical history. It is issued for specific purposes and addressed to medical committees, courts, employers or administrative authorities.</p>

          <h2>Types of reports issued</h2>
          
          <h3>Report for professional purposes</h3>
          <p>Certification of mental fitness for professional licensing or return to work. Often required by public authorities, armed forces or regulated professions.</p>

          <h3>Report for firearm possession or carrying license</h3>
          <p>Required by law for issuing a firearm possession or carrying license in Greece. Includes clinical assessment and psychometric testing.</p>

          <h3>Report for legal use</h3>
          <p>Psychiatric assessment for use in legal proceedings, including divorce, child custody, criminal cases or assessment of legal capacity.</p>

          <h3>Report for disability assessment / KEPA</h3>
          <p>Psychiatric assessment for submission to KEPA — the Greek Disability Certification Center — or IKA, with detailed documentation of mental state and functional impact.</p>

          <h3>Report for educational purposes</h3>
          <p>Certification of mental state for entry into educational institutions, postgraduate programs or programs requiring psychiatric screening.</p>

          <h3>Psychiatric certificate for travel / medication</h3>
          <p>For patients travelling with psychotropic medication, such as anxiolytics or mood stabilizers, who need medical documentation for customs or insurance purposes.</p>

          <div class="mt-20 pt-12 border-t border-slate-200">
            <h2 class="text-2xl font-bold text-blue-900 mb-8">FAQ</h2>
            <div class="space-y-8">
              <div>
                <h3 class="text-lg font-bold text-slate-900 mb-2">How long does it take to issue a report?</h3>
                <p class="text-slate-600">Depending on the type of report, it is usually issued within 2–5 working days after clinical assessment. In urgent cases, it may be issued during the visit.</p>
              </div>
              <div>
                <h3 class="text-lg font-bold text-slate-900 mb-2">Do I need to have visited the clinic before?</h3>
                <p class="text-slate-600">No. Clinical assessment for a medical report can be performed independently of an existing therapeutic relationship.</p>
              </div>
              <div>
                <h3 class="text-lg font-bold text-slate-900 mb-2">Can the report be used in court?</h3>
                <p class="text-slate-600">Yes, if requested for this purpose. In some cases, expert consultant testimony may be required; this can be discussed in advance.</p>
              </div>
              <div>
                <h3 class="text-lg font-bold text-slate-900 mb-2">What does the clinical assessment include?</h3>
                <p class="text-slate-600">Structured psychiatric interview, psychometric tools depending on report type, review of medical history if available, and drafting of a reasoned report.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Internal Links for SEO -->
        <div class="mt-20 pt-12 border-t border-slate-200">
          <h2 class="text-2xl font-bold text-blue-900 mb-8">Related Services</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <a href="/en/ypiresies/psychiatriki-parakolouthisi/" class="p-6 bg-blue-50 rounded-2xl border border-blue-100 hover:border-blue-300 transition-all font-bold text-blue-900">Psychiatric follow-up &rarr;</a>
            <a href="/en/ypiresies/psychometrika-test/" class="p-6 bg-blue-50 rounded-2xl border border-blue-100 hover:border-blue-300 transition-all font-bold text-blue-900">Psychometric tests &rarr;</a>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
