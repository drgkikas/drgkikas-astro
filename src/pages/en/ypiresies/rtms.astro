---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/UI/Header.astro';
import Footer from '../../../components/UI/Footer.astro';

const title = "rTMS & neuromodulation";
const description = "Advanced neuromodulation treatments — rTMS and iTBS — without medication, using first-, second- and third-line protocols.";
const canonicalURL = "https://drgkikas.com/en/ypiresies/rtms";

const schemaBundle = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "MedicalProcedure",
      "name": title,
      "description": description,
      "url": canonicalURL
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://drgkikas.com/en" },
        { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://drgkikas.com/en/ypiresies" },
        { "@type": "ListItem", "position": 3, "name": title, "item": canonicalURL }
      ]
    }
  ]
});
---

<Layout title={title} description={description} schema={schemaBundle}>
  <Header />
  <main class="pt-24 pb-16 bg-slate-50 min-h-screen">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Breadcrumbs UI -->
      <nav class="text-sm text-slate-500 mb-8 mt-4">
        <ol class="list-none p-0 inline-flex flex-wrap items-center">
          <li class="flex items-center"><a href="/en" class="hover:text-blue-700 transition-colors">Home</a><svg class="w-3 h-3 mx-2 opacity-50" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path></svg></li>
          <li class="flex items-center"><a href="/en/ypiresies/" class="hover:text-blue-700 transition-colors">Services</a><svg class="w-3 h-3 mx-2 opacity-50" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path></svg></li>
          <li class="flex items-center"><span class="text-slate-800 font-medium">rTMS</span></li>
        </ol>
      </nav>

      <div class="glass-card p-10 md:p-16">
        <div class="text-center mb-16 border-b border-slate-200 pb-12">
          <h1 class="text-4xl md:text-5xl font-bold text-blue-900 mb-8 leading-normal">{title}</h1>
          <p class="text-xl md:text-2xl text-slate-600 leading-relaxed max-w-3xl mx-auto">{description}</p>
        </div>
        
        <div class="prose prose-lg md:prose-xl prose-blue max-w-none text-slate-700
          prose-p:mb-10 prose-p:leading-[1.9]
          prose-headings:text-blue-900 prose-headings:font-bold 
          prose-h2:mt-20 prose-h2:mb-8 prose-h2:border-b prose-h2:border-slate-100 prose-h2:pb-4
          prose-h3:mt-14 prose-h3:mb-6
          prose-a:font-bold prose-a:text-blue-900 prose-a:bg-blue-100 prose-a:px-2 prose-a:py-0.5 prose-a:rounded-lg prose-a:no-underline hover:prose-a:bg-blue-700 hover:prose-a:text-white prose-a:transition-colors
          prose-ul:my-10 prose-li:my-5 marker:text-blue-500">
          
          <p>Repetitive Transcranial Magnetic Stimulation — rTMS — is one of the most modern, safe and non-invasive methods. It uses targeted magnetic fields to activate or inhibit specific neural networks, regulating brain function with high precision.</p>

          <h2>Therapeutic protocols — first-, second- and third-line</h2>
          <p>At Smart CNS Center, we do not follow a static “one-size-fits-all” approach. Depending on the clinical diagnosis — for example, comorbidity with anxiety or insomnia — and severity, the patient is assigned to first-, second- or third-line therapeutic protocols. This stratification allows us to:</p>
          <ul>
            <li>Cover cases ranging from mild depressive symptoms to formally diagnosed treatment-resistant depression</li>
            <li>Escalate the intervention smoothly when needed, moving to second-line protocols with dual clinical targets</li>
          </ul>

          <h2>Applications by diagnosis</h2>
          <h3>Major depressive disorder and bipolar disorder</h3>
          <p>Gradual reduction of symptoms without the systemic side effects of antidepressants. Specific protocols are available for patients with prominent panic attacks or anxiety.</p>

          <h3>Obsessive-compulsive disorder — OCD</h3>
          <p>Specialized stimulation protocols aimed at reducing obsessions and compulsions.</p>

          <h3>Addictions — cocaine and alcohol</h3>
          <p>Treatment is divided into an active treatment cycle, aimed at reducing craving, and a maintenance stage, usually monthly, to reduce relapse risk.</p>

          <h3>Chronic primary insomnia</h3>
          <p>Regulation of circadian rhythm from the early sessions.</p>

          <p>The treatment plan is adapted to your budget, selecting the appropriate protocol after clinical assessment. Hospitalization is not required and you can return immediately to your activities.</p>
        </div>

        <!-- Internal Links for SEO -->
        <div class="mt-20 pt-12 border-t border-slate-200">
          <h2 class="text-2xl font-bold text-blue-900 mb-8">Related Conditions</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <a href="/en/diataraxes/katathlipsi/" class="p-6 bg-blue-50 rounded-2xl border border-blue-100 hover:border-blue-300 transition-all font-bold text-blue-900">Depression (MDD) &rarr;</a>
            <a href="/en/diataraxes/ideopsychanagkastiki-diatarachi/" class="p-6 bg-blue-50 rounded-2xl border border-blue-100 hover:border-blue-300 transition-all font-bold text-blue-900">Obsessive-Compulsive Disorder &rarr;</a>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
