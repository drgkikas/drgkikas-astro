---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/UI/Header.astro';
import Footer from '../../../components/UI/Footer.astro';

const title = "rTMS e neuromodulazione";
const description = "Trattamenti avanzati di neuromodulazione — rTMS e iTBS — senza farmaci, con protocolli di prima, seconda e terza linea.";
const canonicalURL = "https://drgkikas.com/it/ypiresies/rtms";

const schemaBundle = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "MedicalProcedure",
      "name": title,
      "description": description,
      "url": canonicalURL
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://drgkikas.com/it" },
        { "@type": "ListItem", "position": 2, "name": "Servizi", "item": "https://drgkikas.com/it/ypiresies" },
        { "@type": "ListItem", "position": 3, "name": title, "item": canonicalURL }
      ]
    }
  ]
});
---

<Layout title={title} description={description} schema={schemaBundle}>
  <Header />
  <main class="pt-24 pb-16 bg-slate-50 min-h-screen">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Breadcrumbs UI -->
      <nav class="text-sm text-slate-500 mb-8 mt-4">
        <ol class="list-none p-0 inline-flex flex-wrap items-center">
          <li class="flex items-center"><a href="/it" class="hover:text-blue-700 transition-colors">Home</a><svg class="w-3 h-3 mx-2 opacity-50" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path></svg></li>
          <li class="flex items-center"><a href="/it/ypiresies/" class="hover:text-blue-700 transition-colors">Servizi</a><svg class="w-3 h-3 mx-2 opacity-50" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path></svg></li>
          <li class="flex items-center"><span class="text-slate-800 font-medium">rTMS</span></li>
        </ol>
      </nav>

      <div class="glass-card p-10 md:p-16">
        <div class="text-center mb-16 border-b border-slate-200 pb-12">
          <h1 class="text-4xl md:text-5xl font-bold text-blue-900 mb-8 leading-normal">{title}</h1>
          <p class="text-xl md:text-2xl text-slate-600 leading-relaxed max-w-3xl mx-auto">{description}</p>
        </div>
        
        <div class="prose prose-lg md:prose-xl prose-blue max-w-none text-slate-700
          prose-p:mb-10 prose-p:leading-[1.9]
          prose-headings:text-blue-900 prose-headings:font-bold 
          prose-h2:mt-20 prose-h2:mb-8 prose-h2:border-b prose-h2:border-slate-100 prose-h2:pb-4
          prose-h3:mt-14 prose-h3:mb-6
          prose-a:font-bold prose-a:text-blue-900 prose-a:bg-blue-100 prose-a:px-2 prose-a:py-0.5 prose-a:rounded-lg prose-a:no-underline hover:prose-a:bg-blue-700 hover:prose-a:text-white prose-a:transition-colors
          prose-ul:my-10 prose-li:my-5 marker:text-blue-500">
          
          <p>La Stimolazione Magnetica Transcranica Ripetitiva — rTMS — è uno dei metodi più moderni, sicuri e non invasivi. Utilizza campi magnetici mirati per attivare o inibire specifiche reti neuronali, regolando la funzione cerebrale con elevata precisione.</p>

          <h2>Protocolli terapeutici — prima, seconda e terza linea</h2>
          <p>Presso Smart CNS Center non seguiamo un approccio statico “one-size-fits-all”. In base alla diagnosi clinica — ad esempio comorbidità con ansia o insonnia — e alla gravità, il paziente viene assegnato a protocolli terapeutici di prima, seconda o terza linea. Questa stratificazione permette di:</p>
          <ul>
            <li>Coprire casi che vanno da sintomi depressivi lievi fino alla depressione resistente al trattamento formalmente diagnosticata</li>
            <li>Intensificare gradualmente l’intervento quando necessario, passando a protocolli di seconda linea con doppio target clinico</li>
          </ul>

          <h2>Applicazioni per diagnosi</h2>
          <h3>Disturbo depressivo maggiore e disturbo bipolare</h3>
          <p>Riduzione graduale dei sintomi senza gli effetti collaterali sistemici degli antidepressivi. Sono disponibili protocolli specifici per pazienti con attacchi di panico o ansia marcati.</p>

          <h3>Disturbo ossessivo-compulsivo — OCD</h3>
          <p>Protocolli di stimolazione specialistici mirati alla riduzione di ossessioni e compulsioni.</p>

          <h3>Dipendenze — cocaina e alcol</h3>
          <p>Il trattamento è suddiviso in un ciclo terapeutico attivo, finalizzato alla riduzione del craving, e in una fase di mantenimento, generalmente mensile, per ridurre il rischio di ricaduta.</p>

          <h3>Insonnia primaria cronica</h3>
          <p>Regolazione del ritmo circadiano fin dalle prime sedute.</p>

          <p>Il piano terapeutico viene adattato al vostro budget, scegliendo il protocollo appropriato dopo la valutazione clinica. Non è necessario il ricovero e potete tornare subito alle vostre attività.</p>
        </div>

        <!-- Internal Links for SEO -->
        <div class="mt-20 pt-12 border-t border-slate-200">
          <h2 class="text-2xl font-bold text-blue-900 mb-8">Condizioni Correlate</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <a href="/it/diataraxes/katathlipsi/" class="p-6 bg-blue-50 rounded-2xl border border-blue-100 hover:border-blue-300 transition-all font-bold text-blue-900">Depressione (MDD) &rarr;</a>
            <a href="/it/diataraxes/ideopsychanagkastiki-diatarachi/" class="p-6 bg-blue-50 rounded-2xl border border-blue-100 hover:border-blue-300 transition-all font-bold text-blue-900">Disturbo Ossessivo-Compulsivo &rarr;</a>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
