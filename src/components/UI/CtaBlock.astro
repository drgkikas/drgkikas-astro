---
interface Props {
  primaryHref?: string;
  secondaryHref?: string;
  title?: string;
  text?: string;
}
const { primaryHref = "#", secondaryHref, title = "", text = "" } = Astro.props;
---
<div class="glass-card p-8 md:p-12 mb-12 text-center">
  {title ? <h2 class="text-2xl font-semibold mb-4 text-slate-900">{title}</h2> : null}
  {text ? <p class="mb-6 text-slate-700">{text}</p> : null}
  <a href={primaryHref} class="btn-primary inline-block mx-2">{title || 'Κλείστε ραντεβού αξιολόγησης'}</a>
  {secondaryHref ? <a href={secondaryHref} class="btn-secondary inline-block mx-2">Διαβάστε περισσότερα</a> : null}
</div>
