---
export interface FaqItem { question: string; answer: string; }
interface Props {
  faqs?: FaqItem[];
}
const { faqs = [] } = Astro.props;
---
<div class="glass-card p-8 md:p-12 mb-12">
  <h2 class="text-2xl font-semibold mb-4 text-slate-900">Συχνές Ερωτήσεις</h2>
  <ul class="space-y-4">
    {faqs.map((item) => (
      <li class="border-b pb-2">
        <details class="group cursor-pointer">
          <summary class="w-full text-left flex justify-between items-center text-slate-800 font-medium list-none">
            <span>{item.question}</span>
            <span class="text-sm group-open:hidden">+</span>
            <span class="text-sm hidden group-open:inline">−</span>
          </summary>
          <p class="mt-2 text-slate-600">{item.answer}</p>
        </details>
      </li>
    ))}
  </ul>
</div>
<style>
  details > summary::-webkit-details-marker {
    display: none;
  }
</style>
