<style is:inline> /* Optimized: Inline CSS to avoid render-blocking */
  .site-footer {
    background-color: #1a1a1a;
    color: #cccccc;
    font-family: inherit;
    margin-top: auto;
  }

  .footer-main {
    padding: 4rem 0 3rem;
  }

  .footer-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 2rem;
  }

  .footer-col-title {
    color: #ffffff;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0 0 1.25rem 0;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid #333333;
    white-space: nowrap;
  }

  .footer-col-text {
    font-size: 0.85rem;
    line-height: 1.7;
    color: #999999;
    margin: 0;
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-links a {
    color: #999999;
    text-decoration: none;
    font-size: 0.85rem;
    transition: all 0.2s ease;
    display: inline-block;
  }

  .footer-links a:hover {
    color: #ffffff;
    transform: translateX(3px);
  }

  .footer-contact {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-contact li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: #999999;
  }

  .footer-contact svg {
    width: 0.9rem;
    height: 0.9rem;
    color: #666666;
    flex-shrink: 0;
  }

  .footer-contact a {
    color: #999999;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-contact a:hover {
    color: #ffffff;
  }

  .footer-bottom {
    background-color: #111111;
    border-top: 1px solid #222222;
    text-align: center;
    padding: 1.25rem 2rem;
  }

  .footer-bottom p {
    margin: 0;
    font-size: 0.75rem;
    color: #666666;
    letter-spacing: 0.02em;
  }

  @media (max-width: 1200px) {
    .footer-inner {
      grid-template-columns: repeat(3, 1fr);
      gap: 3rem;
    }
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: repeat(2, 1fr);
      gap: 2.5rem;
    }
  }

  @media (max-width: 480px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .footer-main {
      padding: 3rem 0;
    }
    .footer-col-title {
        white-space: normal;
    }
  }
</style>
