---
import { getCollection } from 'astro:content';

const allDisorders = await getCollection('disorders');
const allServices = await getCollection('services');

// Manual mapping for titles to match the image exactly
const disorderTitles = {
  'agxodeis-diataraxes': 'Αγχώδεις Διαταραχές',
  'anoies-diataraxes-mnimis': 'Άνοια',
  'adhd-adult': 'ΔΕΠΥ (ADHD) Ενηλίκων',
  'diataraxes-proslipsis-trofis': 'Διαταραχές Πρόσληψης Τροφής',
  'diataraxes-ypnou': 'Διαταραχές Ύπνου',
  'diatarachi-xrisis-alkool': 'Διαταραχή Χρήσης Αλκοόλ',
  'diatarachi-xrisis-kokainis': 'Διαταραχή Χρήσης Κοκαΐνης',
  'dipoliki-diatarachi': 'Διπολική Διαταραχή',
  'ideopsychanagkastiki-diatarachi': 'ΙΔΨ Διαταραχή (OCD)',
  'katathlipsi': 'Κατάθλιψη (MDD)',
  'BODY-DYSMORPHIC': 'Σύμπλεγμα Θερσίτη',
  'psychosomatikes-ekdiloseis': 'Ψυχοσωματικές Εκδηλώσεις',
  'psychotikes-diataraxes': 'Ψυχωτικές Διαταραχές',
  'pmdd': 'PMDD'
};

const serviceTitles = {
  'adhd-evaluation': 'Αξιολόγηση ΔΕΠΥ Ενηλίκων',
  'psychotherapy': 'Στοχευμένη Ψυχοθεραπεία',
  'pgx': 'Φαρμακογονιδιωματική (PGx)',
  'gnomateyseis': 'Ψυχιατρικές Γνωματεύσεις',
  'psychiatriki-parakolouthisi': 'Ψυχιατρική παρακολούθηση',
  'psychotherapeia': 'Ψυχοθεραπεία',
  'psychometrika-test': 'Ψυχομετρικά Τεστ & Αξιολόγηση',
  'online-synedria': 'Online Ψυχιατρική',
  'rtms': 'rTMS'
};

// Map and Sort
const disorders = allDisorders
  .map(d => ({ ...d, displayTitle: disorderTitles[d.id] || d.data.title }))
  .sort((a, b) => a.displayTitle.localeCompare(b.displayTitle, 'el'));

const services = allServices
  .map(s => ({ ...s, displayTitle: serviceTitles[s.id] || s.data.title }))
  .sort((a, b) => a.displayTitle.localeCompare(b.displayTitle, 'el'));
---
<footer class="site-footer">
  <div class="footer-main">
    <div class="footer-inner">

      <!-- Στήλη 1: Μήνυμα Από Τον Ιατρό -->
      <div class="footer-col bio-col">
        <h3 class="footer-col-title">ΜΗΝΥΜΑ ΑΠΟ ΤΟΝ ΙΑΤΡΟ</h3>
        <p class="footer-col-text">
          Στην παρούσα ιστοσελίδα μπορείτε να βρείτε χρήσιμες πληροφορίες που αφορούν την ψυχική υγεία.
          Περιηγηθείτε ελεύθερα και μην διστάσετε να επικοινωνήσετε μαζί μου για οποιαδήποτε διευκρίνιση.
          Καλή περιήγηση!
        </p>
      </div>

      <!-- Στήλη 2: Διαταραχές -->
      <div class="footer-col">
        <h3 class="footer-col-title"><a href="/diataraxes">ΔΙΑΤΑΡΑΧΕΣ</a></h3>
        <ul class="footer-links">
          {disorders.map(dis => (
            <li><a href={`/diataraxes/${dis.id}`}>{dis.displayTitle}</a></li>
          ))}
        </ul>
      </div>

      <!-- Στήλη 3: Υπηρεσίες -->
      <div class="footer-col">
        <h3 class="footer-col-title"><a href="/ypiresies">ΥΠΗΡΕΣΙΕΣ</a></h3>
        <ul class="footer-links">
          {services.map(service => (
            <li><a href={`/ypiresies/${service.id}`}>{service.displayTitle}</a></li>
          ))}
        </ul>
      </div>

      <!-- Στήλη 4: Πηγές & Εργαλεία -->
      <div class="footer-col">
        <h3 class="footer-col-title">ΠΗΓΕΣ & ΕΡΓΑΛΕΙΑ</h3>
        <ul class="footer-links">
          <li><a href="/psychometrika" class="footer-highlight-link">Ψυχομετρικά Τεστ &rarr;</a></li>
          <li><a href="/KnowledgeBase-eBooks">Βιβλιοθήκη & eBooks</a></li>
          <li><a href="/epikoinonia">Επικοινωνία - Ραντεβού</a></li>
          <li><a href="/privacy-policy">Πολιτική Απορρήτου</a></li>
        </ul>
      </div>

      <!-- Στήλη 5: Επικοινωνία -->
      <div class="footer-col">
        <h3 class="footer-col-title">ΕΠΙΚΟΙΝΩΝΙΑ</h3>
        <ul class="footer-contact">
          <li>
            <span>Ξενοφώντος 15Α, Σύνταγμα, Αθήνα</span>
          </li>
          <li>
            <a href="tel:+302118500016" class="footer-tel-link">211 850 0016</a>
          </li>
        </ul>
      </div>

    </div>
  </div>

  <div class="footer-bottom">
    <p>&copy; {new Date().getFullYear()} drGkikas.com - All rights reserved.</p>
  </div>
</footer>

<style is:inline>
  .site-footer {
    background-color: #ffffff;
    color: #333333;
    font-family: inherit;
    border-top: 1px solid #eaeaea;
  }

  .footer-main {
    padding: 5rem 0;
  }

  .footer-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    /* Custom columns to allow enough space for long titles in Col 2 & 3 */
    grid-template-columns: 1.2fr 1.3fr 1.3fr 1fr 0.8fr;
    gap: 2rem;
    align-items: start;
  }

  .footer-col-title {
    color: #1a1a1a;
    font-size: 0.85rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    margin: 0 0 1.5rem 0;
    white-space: nowrap;
  }

  .footer-col-title a {
    color: inherit;
    text-decoration: none;
    border-bottom: 2px solid transparent;
    transition: border-color 0.2s;
  }
  .footer-col-title a:hover {
    border-bottom-color: #084a79;
  }

  .footer-col-text {
    font-size: 0.85rem;
    line-height: 1.7;
    color: #555;
    max-width: 280px;
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .footer-links a {
    color: #084a79;
    text-decoration: underline;
    text-decoration-color: #cbd5e1;
    text-underline-offset: 3px;
    font-size: 0.825rem;
    white-space: nowrap; /* Prevents text from cutting off/wrapping */
    transition: all 0.2s;
  }

  /* Some links in image were black text */
  .footer-links li:nth-child(even) a,
  .footer-links li.no-underline a {
    color: #333;
    text-decoration: none;
  }
  
  /* Reset some specific colors based on image */
  .footer-col:nth-child(2) li:nth-child(6) a,
  .footer-col:nth-child(2) li:nth-child(7) a,
  .footer-col:nth-child(2) li:nth-child(8) a,
  .footer-col:nth-child(2) li:nth-child(12) a,
  .footer-col:nth-child(2) li:nth-child(13) a,
  .footer-col:nth-child(2) li:nth-child(14) a {
    color: #333;
    text-decoration: none;
  }

  .footer-col:nth-child(3) li:nth-child(2) a,
  .footer-col:nth-child(3) li:nth-child(3) a,
  .footer-col:nth-child(3) li:nth-child(6) a {
    color: #333;
    text-decoration: none;
  }

  .footer-links a:hover {
    color: #084a79;
    text-decoration-color: #084a79;
  }

  .footer-highlight-link {
    color: #b15d8d !important; /* Pinkish color from image for Psychometrics */
    font-weight: 700;
  }

  .footer-contact {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .footer-contact li {
    font-size: 0.85rem;
    color: #333;
    line-height: 1.5;
  }
  .footer-tel-link {
    color: #084a79;
    text-decoration: underline;
    font-weight: 600;
  }

  .footer-bottom {
    border-top: 1px solid #f1f5f9;
    padding: 2rem;
    text-align: center;
  }
  .footer-bottom p {
    font-size: 0.75rem;
    color: #94a3b8;
    margin: 0;
  }

  @media (max-width: 1200px) {
    .footer-inner {
      grid-template-columns: repeat(3, 1fr);
      gap: 3rem;
    }
  }
  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
    }
    .footer-links a {
        white-space: normal; /* Allow wrap on mobile if screen is too small */
    }
  }
  @media (max-width: 480px) {
    .footer-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
