---
---
<header class="fixed w-full top-0 z-50 bg-white/90 backdrop-blur-md border-b border-slate-200 transition-all duration-300 shadow-sm" id="main-header">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      
      <!-- Brand Logo -->
      <div class="flex-shrink-0 flex items-center">
        <a href="/" class="flex items-center group">
          <img src="/logo.jpg" alt="Dr. Πασχάλης Γκίκας - Ψυχίατρος" class="h-14 w-auto object-contain transition-transform group-hover:scale-105" />
        </a>
      </div>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex space-x-3 lg:space-x-4 xl:space-x-6 items-center text-sm lg:text-base">
        <a href="/" class="text-slate-600 hover:text-blue-700 font-medium transition-colors">Αρχική</a>
        
        <!-- Ιατρός Dropdown -->
        <div class="relative group py-6">
          <a href="/iatros" class="text-slate-600 group-hover:text-blue-700 font-medium transition-colors flex items-center gap-1">
            Ιατρός
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </a>
          <div class="absolute top-full left-0 w-64 bg-white shadow-xl rounded-xl border border-slate-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform origin-top-left -translate-y-2 group-hover:translate-y-0 p-2 z-50">
            <a href="/iatros#cv" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">Βιογραφικό (CV)</a>
            <a href="/iatros#education" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">Εκπαίδευση & Πιστοποιήσεις</a>
            <a href="/iatros#media" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">Συνεργασίες & Media</a>
          </div>
        </div>

        <!-- Υπηρεσίες Dropdown -->
        <div class="relative group py-6">
          <a href="/ypiresies" class="text-slate-600 group-hover:text-blue-700 font-medium transition-colors flex items-center gap-1">
            Υπηρεσίες
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </a>
          <div class="absolute top-full left-0 w-64 bg-white shadow-xl rounded-xl border border-slate-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform origin-top-left -translate-y-2 group-hover:translate-y-0 p-2 z-50">
            <a href="/ypiresies/psychiatriki-parakolouthisi" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">Ψυχιατρική Παρακολούθηση</a>
            <a href="/ypiresies/psychotherapeia" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">Ψυχοθεραπεία</a>
            <a href="/ypiresies/pgx" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">Φαρμακογονιδιωματική (PGx)</a>
            <a href="/ypiresies/online-synedria" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">Online Συνεδρία</a>
            <a href="/ypiresies/gnomateyseis" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">Γνωματεύσεις / Πιστοποιητικά</a>
            <a href="/ypiresies/psychometrika-test" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">Ψυχομετρικά Τεστ</a>
          </div>
        </div>

        <!-- Διαταραχές Dropdown -->
        <div class="relative group py-6">
          <a href="/diataraxes" class="text-slate-600 group-hover:text-blue-700 font-medium transition-colors flex items-center gap-1">
            Διαταραχές
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </a>
          <div class="absolute top-full left-0 w-72 bg-white shadow-xl rounded-xl border border-slate-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform origin-top-left -translate-y-2 group-hover:translate-y-0 p-2 z-50 max-h-[70vh] overflow-y-auto">
            <a href="/diataraxes/katathlipsi" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">Κατάθλιψη</a>
            <a href="/diataraxes/dipoliki-diatarachi" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">Διπολική Διαταραχή</a>
            <a href="/diataraxes/agxodeis-diataraxes" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">Αγχώδεις Διαταραχές</a>
            <a href="/diataraxes/ideopsychanagkastiki-diatarachi" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">Ιδεοψυχαναγκαστική Διαταραχή (OCD)</a>
            <a href="/diataraxes/diataraxes-ypnou" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">Διαταραχές Ύπνου</a>
            <a href="/diataraxes/psychotikes-diataraxes" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">Ψυχωτικές Διαταραχές</a>
            <a href="/diataraxes/diatarachi-xrisis-kokainis" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">Χρήση Κοκαΐνης</a>
            <a href="/diataraxes/diatarachi-xrisis-alkool" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">Χρήση Αλκοόλ</a>
            <a href="/diataraxes/anoies-diataraxes-mnimis" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">Άνοιες & Διαταραχές Μνήμης</a>
            <a href="/diataraxes/diataraxes-proslipsis-trofis" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">Διαταραχές Πρόσληψης Τροφής</a>
            <a href="/diataraxes/pmdd" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">PMDD</a>
            <a href="/diataraxes/psychosomatikes-ekdiloseis" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">Ψυχοσωματικές Εκδηλώσεις</a>
          </div>
        </div>

        <!-- rTMS Mega Dropdown -->
        <div class="relative group py-6">
          <a href="/rtms" class="text-slate-600 group-hover:text-blue-700 font-medium transition-colors flex items-center gap-1">
            rTMS
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </a>
          <!-- Mega Menu Panel -->
          <div class="absolute top-full -left-[300px] w-[800px] bg-white shadow-2xl rounded-xl border border-slate-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform origin-top -translate-y-2 group-hover:translate-y-0 p-6 z-50 flex gap-8">
            
            <div class="flex-1">
              <h4 class="text-slate-900 font-bold mb-3 border-b pb-2 text-sm uppercase tracking-wider">Βασικές Πληροφορίες</h4>
              <a href="/rtms/core/ti-einai" class="block py-2 text-sm text-slate-600 hover:text-blue-700">Τι είναι (rTMS / iTBS)</a>
              <a href="/rtms/core/asfaleia-parenergeies" class="block py-2 text-sm text-slate-600 hover:text-blue-700">Ασφάλεια & Παρενέργειες</a>
              <a href="/rtms/core/kostos-kai-diadikasia" class="block py-2 text-sm text-slate-600 hover:text-blue-700">Κόστος & Διαδικασία</a>
              <a href="/rtms/core/syxnes" class="block py-2 text-sm text-slate-600 hover:text-blue-700">Συχνές Ερωτήσεις (FAQ)</a>
            </div>

            <div class="flex-1 bg-slate-50 -my-6 p-6 border-l border-r border-slate-100">
              <h4 class="text-slate-900 font-bold mb-3 border-b pb-2 text-sm uppercase tracking-wider">Ενδείξεις</h4>
              <a href="/rtms/endixeis/katathlipsi" class="block py-2 text-sm text-slate-600 hover:text-blue-700">Κατάθλιψη (MDD)</a>
              <a href="/rtms/endixeis/trd" class="block py-2 text-sm text-slate-600 hover:text-blue-700">Ανθεκτική Κατάθλιψη (TRD)</a>
              <a href="/rtms/endixeis/ponos" class="block py-2 text-sm text-slate-600 hover:text-blue-700">Χρόνιος Πόνος</a>
              <a href="/rtms/endixeis/ocd" class="block py-2 text-sm text-slate-600 hover:text-blue-700">Ιδεοψυχαναγκαστική (OCD)</a>
              <a href="/rtms/endixeis/kokaini" class="block py-2 text-sm text-slate-600 hover:text-blue-700">Εθισμός (Κοκαΐνη)</a>
            </div>

            <div class="flex-1">
              <h4 class="text-slate-900 font-bold mb-3 border-b pb-2 text-sm uppercase tracking-wider">Πώς Λειτουργεί</h4>
              <a href="/rtms/pos-leitourgei/neuroplasticity" class="block py-2 text-sm text-slate-600 hover:text-blue-700">Νευροπλαστικότητα</a>
              <a href="/rtms/pos-leitourgei/dlpfc" class="block py-2 text-sm text-slate-600 hover:text-blue-700">Στόχευση DLPFC</a>
              <a href="/rtms/pos-leitourgei/brain-connectivity" class="block py-2 text-sm text-slate-600 hover:text-blue-700">Brain Connectivity</a>
              <a href="/rtms/pos-leitourgei/neural-oscillations" class="block py-2 text-sm text-slate-600 hover:text-blue-700">Neural Oscillations</a>
              <a href="/rtms/pos-leitourgei/motor-threshold" class="block py-2 text-sm text-slate-600 hover:text-blue-700">Motor Threshold / rMT</a>
              <a href="/rtms/pos-leitourgei/mep" class="block py-2 text-sm text-slate-600 hover:text-blue-700">MEP</a>
            </div>

          </div>
        </div>

        <a href="/psychometrika" class="text-slate-600 hover:text-blue-700 font-medium transition-colors">Ψυχομετρικά</a>
        <a href="/KnowledgeBase-eBooks" class="text-slate-600 hover:text-blue-700 font-medium transition-colors flex flex-col items-center justify-center leading-tight">
          <span>eBooks /</span>
          <span class="text-xs">Knowledge Base</span>
        </a>
        <a href="/arthra-blog" class="text-slate-600 hover:text-blue-700 font-medium transition-colors">Blog</a>
      </nav>

      <!-- CTA Contact -->
      <div class="hidden md:flex items-center">
        <a href="#contact" class="btn-primary px-5 py-2.5 text-sm">Κλειστε Ραντεβου</a>
      </div>

    </div>
  </div>
</header>

<script>
  window.addEventListener('scroll', () => {
    const header = document.getElementById('main-header');
    if (window.scrollY > 20) {
      header?.classList.add('shadow-md');
    } else {
      header?.classList.remove('shadow-md');
    }
  });
</script>
