---
---
<header class="fixed w-full top-0 z-50 bg-white/90 backdrop-blur-md border-b border-slate-200 transition-all duration-300 shadow-sm" id="main-header">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      
      <!-- Brand Logo -->
      <div class="flex-shrink-0 flex items-center">
        <a href="/" class="flex flex-col text-slate-900 group">
          <span class="text-xl font-bold tracking-tight text-blue-900 leading-tight">Dr. Πασχάλης Γκίκας</span>
          <span class="text-xs font-semibold text-slate-500 uppercase tracking-widest">Ψυχιατρος - Ψυχοθεραπευτης</span>
        </a>
      </div>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex space-x-8">
        <a href="/" class="text-slate-600 hover:text-blue-700 font-medium transition-colors">Ιατρός</a>
        <a href="/#pathologies" class="text-slate-600 hover:text-blue-700 font-medium transition-colors">Υπηρεσίες</a>
        <a href="/diataraxes/katathlipsi" class="text-slate-600 hover:text-blue-700 font-medium transition-colors">Διαταραχές</a>
        <a href="/rtms/ti-einai-rtms" class="text-slate-600 hover:text-blue-700 font-medium transition-colors">rTMS Pillar</a>
      </nav>

      <!-- CTA Contact -->
      <div class="hidden md:flex items-center">
        <a href="#contact" class="btn-primary px-5 py-2.5 text-sm">Κλειστε Ραντεβου</a>
      </div>

    </div>
  </div>
</header>

<script>
  window.addEventListener('scroll', () => {
    const header = document.getElementById('main-header');
    if (window.scrollY > 20) {
      header?.classList.add('shadow-md');
    } else {
      header?.classList.remove('shadow-md');
    }
  });
</script>
