    core_info: "Βασικές Πληροφορίες",
    mechanism: "Πώς Λειτουργεί"
  },
  en: {
    home: "Home",
    doctor: "Doctor",
    services: "Services",
    disorders: "Disorders",
    rtms: "rTMS",
    psychometrics: "Psychometrics",
    blog: "Blog",
    contact_btn: "Book Online Session",
    cv: "Biography (CV)",
    edu: "Education & Certifications",
    media: "Media & Collaborations",
    psychiatry: "Psychiatric Monitoring",
    psychotherapy: "Psychotherapy",
    pgx_nav: "Pharmacogenomics (PGx)",
    online: "Online Session",
    certificates: "Certificates / Reports",
    adhd_eval: "Adult ADHD Evaluation",
    all_services: "All Services",
    indications: "Indications",
    faq: "FAQ",
    how_it_works: "How it works",
    cost: "Cost & Procedure",
    depression: "Depression",
    pain: "Chronic Pain",
    ocd: "OCD",
    addiction: "Addiction (Cocaine)",
    what_is_rtms: "What is rTMS",
    safety: "Safety & Side Effects — What to Expect",
    trd: "Resistant Depression (TRD)",
    core_info: "Core Information",
    mechanism: "How it works"
  },
  it: {
    home: "Home",
    doctor: "Medico",
    services: "Servizi",
    disorders: "Disturbi psichiatrici",
    rtms: "rTMS",
    psychometrics: "Psicometria",
    blog: "Blog",
    contact_btn: "Prenota Sessione Online",
    cv: "Biografia (CV)",
    edu: "Istruzione e Certificazioni",
    media: "Media e Collaborazioni",
    psychiatry: "Monitoraggio Psichiatrico",
    psychotherapy: "Psicoterapia",
    pgx_nav: "Farmacogenomica (PGx)",
    online: "Sessione Online",
    certificates: "Certificati / Referti",
    adhd_eval: "Valutazione ADHD Adulti",
    all_services: "Tutti i Servizi",
    indications: "Indicazioni",
    faq: "FAQ",
    how_it_works: "Come funziona",
    cost: "Costi e Procedura",
    depression: "Depressione",
    pain: "Dolore Cronico",
    ocd: "DOC",
    addiction: "Dipendenza (Cocaina)",
    what_is_rtms: "Cos'è l'rTMS",
    safety: "Sicurezza ed Effetti Collaterali — Cosa Aspettarsi",
    trd: "Depressione Resistente (TRD)",
    core_info: "Informazioni di Base",
    mechanism: "Come funziona"
  }
};

const labels = t[currentLocale] || t.el;
---
<header class="fixed w-full top-0 z-50 bg-white/90 backdrop-blur-md border-b border-slate-200 transition-all duration-300 shadow-sm" id="main-header">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      
      <!-- Brand Logo -->
      <div class="flex-shrink-0 flex items-center">
        <a href={langPrefix + "/"} class="flex items-center group">
          <img src="/logo.jpg" alt={labels.doctor + " - " + labels.home} width="200" height="80" fetchpriority="high" decoding="sync" class="h-14 w-auto object-contain transition-transform group-hover:scale-105" />
        </a>
      </div>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex space-x-3 lg:space-x-4 xl:space-x-6 items-center text-sm lg:text-base">
        <a href={langPrefix + "/"} class="text-slate-600 hover:text-blue-700 font-medium transition-colors">{labels.home}</a>
        
        <!-- Ιατρός Dropdown -->
        <div class="relative group py-6">
          <a href={langPrefix + "/iatros"} class="text-slate-600 group-hover:text-blue-700 font-medium transition-colors flex items-center gap-1">
            {labels.doctor}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </a>
          <div class="absolute top-full left-0 w-64 bg-white shadow-xl rounded-xl border border-slate-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform origin-top-left -translate-y-2 group-hover:translate-y-0 p-2 z-50">
            <a href={langPrefix + "/iatros#cv"} class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">{labels.cv}</a>
            <a href={langPrefix + "/iatros#education"} class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">{labels.edu}</a>
            <a href={langPrefix + "/iatros#media"} class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">{labels.media}</a>
          </div>
        </div>

        <!-- Υπηρεσίες Dropdown -->
        <div class="relative group py-6">
          <a href={langPrefix + "/ypiresies"} class="text-slate-600 group-hover:text-blue-700 font-medium transition-colors flex items-center gap-1">
            {labels.services}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </a>
          <div class="absolute top-full left-0 w-64 bg-white shadow-xl rounded-xl border border-slate-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform origin-top-left -translate-y-2 group-hover:translate-y-0 p-2 z-50">
            <a href={langPrefix + "/rtms/core/ti-einai"} class="block px-4 py-2 text-sm text-blue-700 font-bold hover:bg-blue-50 rounded-lg">{labels.what_is_rtms}</a>
            <div class="my-1 border-b border-slate-100"></div>
            <a href={langPrefix + "/ypiresies/psychiatriki-parakolouthisi"} class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">{labels.psychiatry}</a>
            <a href={langPrefix + "/ypiresies/psychotherapeia"} class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">{labels.psychotherapy}</a>
            <a href={langPrefix + "/ypiresies/pgx"} class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">{labels.pgx_nav}</a>
            <a href={langPrefix + "/ypiresies/online-synedria"} class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">{labels.online}</a>
            <a href={langPrefix + "/ypiresies/gnomateyseis"} class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">{labels.certificates}</a>
            <a href={langPrefix + "/ypiresies/adhd-evaluation"} class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">{labels.adhd_eval}</a>
          </div>
        </div>

        <!-- Διαταραχές Dropdown -->
        <div class="relative group py-6">
          <a href={langPrefix + "/diataraxes"} class="text-slate-600 group-hover:text-blue-700 font-medium transition-colors flex items-center gap-1">
            {labels.disorders}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </a>
          <div class="absolute top-full left-0 w-72 bg-white shadow-xl rounded-xl border border-slate-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform origin-top-left -translate-y-2 group-hover:translate-y-0 p-2 z-50 max-h-[70vh] overflow-y-auto">
            <a href={langPrefix + "/diataraxes/agxodeis-diataraxes"} class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">{currentLocale === 'el' ? 'Αγχώδεις Διαταραχές' : 'Anxiety Disorders'}</a>
            <a href={langPrefix + "/diataraxes/adhd-adult"} class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">{currentLocale === 'el' ? 'ΔΕΠΥ Ενηλίκων' : 'Adult ADHD'}</a>
            <a href={langPrefix + "/diataraxes/anoies-diataraxes-mnimis"} class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">{currentLocale === 'el' ? 'Άνοιες & Διαταραχές Μνήμης' : 'Dementia & Memory'}</a>
            <a href={langPrefix + "/diataraxes/dipoliki-diatarachi"} class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">{currentLocale === 'el' ? 'Διπολική Διαταραχή' : 'Bipolar Disorder'}</a>
            <a href={langPrefix + "/diataraxes/katathlipsi"} class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">{labels.depression}</a>
            <a href={langPrefix + "/diataraxes/ideopsychanagkastiki-diatarachi"} class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">{labels.ocd}</a>
            <a href={langPrefix + "/diataraxes/diataraxes-proslipsis-trofis"} class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">{currentLocale === 'el' ? 'Διαταραχές Πρόσληψης Τροφής' : 'Eating Disorders'}</a>
            <a href={langPrefix + "/diataraxes/diataraxes-ypnou"} class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">{currentLocale === 'el' ? 'Διαταραχές Ύπνου' : 'Sleep Disorders'}</a>
            <a href={langPrefix + "/diataraxes/pmdd"} class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">PMDD</a>
            <a href={langPrefix + "/diataraxes/body-dysmorphic"} class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">{currentLocale === 'el' ? 'Σύμπλεγμα Θερσίτη (BDD)' : 'Body Dysmorphic (BDD)'}</a>
            <a href={langPrefix + "/diataraxes/diatarachi-xrisis-alkool"} class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">{currentLocale === 'el' ? 'Διαταραχή Χρήσης Αλκοόλ' : 'Alcohol Use Disorder'}</a>
            <a href={langPrefix + "/diataraxes/diatarachi-xrisis-kokainis"} class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">{currentLocale === 'el' ? 'Διαταραχή Χρήσης Κοκαΐνης' : 'Cocaine Use Disorder'}</a>
            <a href={langPrefix + "/diataraxes/psychosomatikes-ekdiloseis"} class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">{currentLocale === 'el' ? 'Ψυχοσωματικές Εκδηλώσεις' : 'Psychosomatic Manifestations'}</a>
            <a href={langPrefix + "/diataraxes/psychotikes-diataraxes"} class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 rounded-lg">{currentLocale === 'el' ? 'Ψυχωτικές Διαταραχές' : 'Psychotic Disorders'}</a>
          </div>
        </div>

        <!-- rTMS Mega Dropdown -->
        <div class="relative group py-6">
          <a href={langPrefix + "/rtms"} class="text-slate-600 group-hover:text-blue-700 font-medium transition-colors flex items-center gap-1">
            {labels.rtms}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </a>
          <!-- Mega Menu Panel -->
          <div class="absolute top-full -left-[300px] w-[800px] bg-white shadow-2xl rounded-xl border border-slate-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform origin-top -translate-y-2 group-hover:translate-y-0 p-6 z-50 flex gap-8">
            
            <div class="flex-1">
              <p class="text-slate-900 font-bold mb-3 border-b pb-2 text-sm uppercase tracking-wider">{labels.core_info}</p>
              <a href={langPrefix + "/rtms/core/ti-einai"} class="block py-2 text-sm text-slate-600 hover:text-blue-700">{labels.what_is_rtms}</a>
              <a href={langPrefix + "/rtms/core/asfaleia-parenergeies"} class="block py-2 text-sm text-slate-600 hover:text-blue-700">{labels.safety}</a>
              <a href={langPrefix + "/rtms/core/kostos-kai-diadikasia"} class="block py-2 text-sm text-slate-600 hover:text-blue-700">{labels.cost}</a>
              <a href={langPrefix + "/rtms/core/syxnes"} class="block py-2 text-sm text-slate-600 hover:text-blue-700">{labels.faq}</a>
            </div>

            <div class="flex-1 bg-slate-50 -my-6 p-6 border-l border-r border-slate-100">
              <p class="text-slate-900 font-bold mb-3 border-b pb-2 text-sm uppercase tracking-wider">{labels.indications}</p>
              <a href={langPrefix + "/rtms/endixeis/katathlipsi"} class="block py-2 text-sm text-slate-600 hover:text-blue-700">{labels.depression}</a>
              <a href={langPrefix + "/rtms/endixeis/trd"} class="block py-2 text-sm text-slate-600 hover:text-blue-700">{labels.trd}</a>
              <a href={langPrefix + "/rtms/endixeis/ponos"} class="block py-2 text-sm text-slate-600 hover:text-blue-700">{labels.pain}</a>
              <a href={langPrefix + "/rtms/endixeis/ocd"} class="block py-2 text-sm text-slate-600 hover:text-blue-700">{labels.ocd}</a>
              <a href={langPrefix + "/rtms/endixeis/kokaini"} class="block py-2 text-sm text-slate-600 hover:text-blue-700">{labels.addiction}</a>
            </div>

            <div class="flex-1">
              <p class="text-slate-900 font-bold mb-3 border-b pb-2 text-sm uppercase tracking-wider">{labels.mechanism}</p>
              <a href={langPrefix + "/rtms/pos-leitourgei/neuroplasticity"} class="block py-2 text-sm text-slate-600 hover:text-blue-700">{currentLocale === 'it' ? 'Neuroplasticità' : (currentLocale === 'en' ? 'Neuroplasticity' : 'Νευροπλαστικότητα')}</a>
              <a href={langPrefix + "/rtms/pos-leitourgei/neuromodulation"} class="block py-2 text-sm text-slate-600 hover:text-blue-700">{currentLocale === 'it' ? 'Neuromodulazione' : (currentLocale === 'en' ? 'Neuromodulation' : 'Νευροτροποποίηση')}</a>
              <a href={langPrefix + "/rtms/pos-leitourgei/dlpfc"} class="block py-2 text-sm text-slate-600 hover:text-blue-700">{currentLocale === 'it' ? 'Ruolo della DLPFC' : (currentLocale === 'en' ? 'DLPFC Targeting' : 'Στόχευση DLPFC')}</a>
              <a href={langPrefix + "/rtms/pos-leitourgei/brain-connectivity"} class="block py-2 text-sm text-slate-600 hover:text-blue-700">{currentLocale === 'it' ? 'Connettività cerebrale' : (currentLocale === 'en' ? 'Brain Connectivity' : 'Εγκεφαλική Συνδεσιμότητα')}</a>
              <a href={langPrefix + "/rtms/pos-leitourgei/neural-oscillations"} class="block py-2 text-sm text-slate-600 hover:text-blue-700">{currentLocale === 'it' ? 'Oscillazioni neurali' : (currentLocale === 'en' ? 'Neural Oscillations' : 'Νευρωνικές Ταλαντώσεις')}</a>
              <a href={langPrefix + "/rtms/pos-leitourgei/motor-threshold"} class="block py-2 text-sm text-slate-600 hover:text-blue-700">{currentLocale === 'it' ? 'Soglia Motoria (rMT)' : (currentLocale === 'en' ? 'Motor Threshold (rMT)' : 'Κινητικό Κατώφλι (rMT)')}</a>
              <a href={langPrefix + "/rtms/pos-leitourgei/mep"} class="block py-2 text-sm text-slate-600 hover:text-blue-700">{currentLocale === 'it' ? 'Potenziale Evocato Motorio (MEP)' : (currentLocale === 'en' ? 'Motor Evoked Potential (MEP)' : 'Κινητικό Προκλητό Δυναμικό (MEP)')}</a>
            </div>

          </div>
        </div>

        { (currentLocale === 'el' || !currentLocale) && (
          <a href={langPrefix + "/psychometrika"} class="text-blue-700 font-bold transition-colors bg-blue-50 px-3 py-1.5 rounded-lg hover:bg-blue-100">{labels.psychometrics}</a>
        )}
        <!-- Knowledge Base Special Item -->
        <a href={langPrefix + "/KnowledgeBase-eBooks"} class="flex flex-col items-center justify-center group/kb px-3 py-1 rounded-xl hover:bg-slate-50 transition-all duration-300 relative mx-1">
          <span class="text-[9px] font-black uppercase tracking-[0.15em] text-slate-400 group-hover/kb:text-blue-500 transition-colors leading-none mb-0.5">Knowledge Base</span>
          <span class="text-[13px] font-extrabold text-slate-700 group-hover/kb:text-slate-900 transition-colors leading-none tracking-tight">
            <span class="text-blue-600 group-hover/kb:text-blue-700">&</span> eBooks
          </span>
          <div class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-0 h-0.5 bg-blue-600 group-hover/kb:w-1/2 transition-all duration-500 rounded-full"></div>
        </a>
        <a href={langPrefix + "/arthra-blog"} class="text-slate-600 hover:text-blue-700 font-medium transition-colors">{labels.blog}</a>

        <!-- Language Switcher -->
        <div class="relative group py-6 ml-2">
          <button class="flex items-center gap-1.5 text-slate-600 hover:text-blue-700 font-bold text-sm bg-slate-50 px-2 py-1 rounded-md transition-all">
            <span class="text-lg leading-none">🌐</span>
            <span class="uppercase">{Astro.currentLocale || 'el'}</span>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </button>
          <div class="absolute top-full right-0 w-32 bg-white shadow-xl rounded-xl border border-slate-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform origin-top-right -translate-y-2 group-hover:translate-y-0 p-1.5 z-50">
            <a href="/" class={`flex items-center gap-2 px-3 py-2 text-xs font-bold rounded-lg ${Astro.currentLocale === 'el' || !Astro.currentLocale ? 'text-blue-700 bg-blue-50' : 'text-slate-600 hover:bg-slate-50 hover:text-blue-700'}`}>
              <span>🇬🇷</span> Ελληνικά
            </a>
            <a href="/en" class={`flex items-center gap-2 px-3 py-2 text-xs font-bold rounded-lg ${Astro.currentLocale === 'en' ? 'text-blue-700 bg-blue-50' : 'text-slate-600 hover:bg-slate-50 hover:text-blue-700'}`}>
              <span>🇺🇸</span> English
            </a>
            <a href="/it" class={`flex items-center gap-2 px-3 py-2 text-xs font-bold rounded-lg ${Astro.currentLocale === 'it' ? 'text-blue-700 bg-blue-50' : 'text-slate-600 hover:bg-slate-50 hover:text-blue-700'}`}>
              <span>🇮🇹</span> Italiano
            </a>
          </div>
        </div>
      </nav>

      <!-- CTA Contact -->
      <div class="hidden md:flex items-center">
        <a href="https://appt.link/meet-with-paschalis-gkikas/therapy-session" target="_blank" rel="noopener noreferrer" class="btn-primary px-5 py-2.5 text-sm" aria-label={labels.contact_btn}>{labels.contact_btn}</a>
      </div>

      <!-- Mobile Menu Button -->
      <div class="flex items-center md:hidden">
        <button aria-label="Μενού" class="text-slate-600 hover:text-blue-900 focus:outline-none p-2 transition-colors" id="mobile-menu-btn">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M4 6h16M4 12h16M4 18h16" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
          </svg>
        </button>
      </div>

    </div>

    <!-- Mobile Menu Panel -->
    <div class="md:hidden hidden bg-white border-t border-slate-100 shadow-xl absolute left-0 w-full max-h-[80vh] overflow-y-auto" id="mobile-menu">
      <div class="px-4 py-4 space-y-1 bg-white">
        <a class="block px-3 py-2.5 text-base font-semibold text-slate-800 hover:bg-slate-50 hover:text-blue-700 rounded-lg" href={langPrefix + "/"}>{labels.home}</a>
        
        <div class="py-2 border-t border-slate-100 mt-2 pt-2">
          <div class="px-3 py-1 text-xs font-bold text-slate-400 uppercase tracking-widest">{labels.doctor}</div>
          <a class="block pl-5 pr-3 py-2 text-sm text-slate-600 hover:text-blue-700 hover:bg-slate-50 rounded-lg" href={langPrefix + "/iatros"}>{labels.cv}</a>
          <a class="block pl-5 pr-3 py-2 text-sm text-slate-600 hover:text-blue-700 hover:bg-slate-50 rounded-lg" href={langPrefix + "/iatros#education"}>{labels.edu}</a>
          <a class="block pl-5 pr-3 py-2 text-sm text-slate-600 hover:text-blue-700 hover:bg-slate-50 rounded-lg" href={langPrefix + "/iatros#media"}>{labels.media}</a>
        </div>

        <div class="py-2 border-t border-slate-100 mt-2 pt-2">
          <div class="px-3 py-1 text-xs font-bold text-slate-400 uppercase tracking-widest">{labels.services}</div>
