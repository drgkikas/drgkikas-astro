---
const { currentLocale } = Astro;
const langPrefix = currentLocale && currentLocale !== 'el' ? `/${currentLocale}` : '';

const t = {
  el: {
    home: "Αρχική",
    doctor: "Ιατρός",
    services: "Υπηρεσίες",
    disorders: "Διαταραχές",
    rtms: "rTMS",
    psychometrics: "Ψυχομετρικά",
    blog: "Blog",
    contact_btn: "Κλείστε Online Συνεδρία",
    cv: "Βιογραφικό (CV)",
    edu: "Εκπαίδευση & Πιστοποιήσεις",
    media: "Συνεργασίες & Media",
    psychiatry: "Ψυχιατρική Παρακολούθηση",
    psychotherapy: "Ψυχοθεραπεία",
    pgx_nav: "Φαρμακογονιδιωματική (PGx)",
    online: "Online Συνεδρία",
    certificates: "Γνωματεύσεις / Πιστοποιητικά",
    adhd_eval: "Αξιολόγηση ΔΕΠΥ (ADHD)",
