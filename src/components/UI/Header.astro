---
---
<header class="fixed w-full top-0 z-50 bg-white/90 backdrop-blur-md border-b border-slate-200 transition-all duration-300 shadow-sm" id="main-header">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      
      <!-- Brand Logo -->
      <div class="flex-shrink-0 flex items-center">
        <a href="/" class="flex gap-2 items-center text-slate-900 group">
          <svg class="h-8 w-8 text-blue-700" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
          <span class="text-xl font-bold tracking-tight">Smart <span class="text-blue-700">CNS</span> Center</span>
        </a>
      </div>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex space-x-8">
        <a href="/#pathologies" class="text-slate-600 hover:text-blue-700 font-medium transition-colors">Data Matrix</a>
        <a href="/rtms/ti-einai-rtms" class="text-slate-600 hover:text-blue-700 font-medium transition-colors">N-Modulation (rTMS)</a>
        <a href="/ypiresies/farmakogonidiomatiki" class="text-slate-600 hover:text-blue-700 font-medium transition-colors">Φαρμακογονιδιωματική</a>
        <a href="/#tests" class="text-slate-600 hover:text-blue-700 font-medium transition-colors">Ψυχομετρικά Web-Tests</a>
      </nav>

      <!-- CTA Contact -->
      <div class="hidden md:flex items-center">
        <a href="#contact" class="btn-primary px-5 py-2.5 text-sm">Κλειστε Ραντεβου</a>
      </div>

    </div>
  </div>
</header>

<script>
  window.addEventListener('scroll', () => {
    const header = document.getElementById('main-header');
    if (window.scrollY > 20) {
      header?.classList.add('shadow-md');
    } else {
      header?.classList.remove('shadow-md');
    }
  });
</script>
