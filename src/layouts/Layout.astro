---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonicalURL?: string;
}

const { title, description = "Πασχάλης Γκίκας — Ψυχίατρος στην Αθήνα. Εξειδικευμένες υπηρεσίες rTMS, Φαρμακογονιδιωματικής και Ψυχοθεραπείας στο Smart CNS Center.", canonicalURL } = Astro.props;
const canonical = canonicalURL ?? new URL(Astro.url.pathname, 'https://drgkikas-astro.pages.dev').href;
---

<!doctype html>
<html lang="el" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    <meta name="description" content={description} />
    {Astro.url.hostname.includes('pages.dev') && (
      <meta name="robots" content="noindex, nofollow" />
    )}
    <script type="application/ld+json" set:html={`
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Physician",
            "name": "Πασχάλης Γκίκας",
            "description": "Ψυχίατρος - Ψυχοθεραπευτής με εξειδίκευση στη Νευροτροποποίηση (rTMS / tDCS) και Φαρμακογονιδιωματική.",
            "url": "https://drgkikas.com",
            "image": "https://drgkikas.com/wp-content/uploads/2021/01/logo.png",
            "telephone": "+302118500016",
            "email": "contact@drgkikas.com",
            "address": {
              "@type": "PostalAddress",
              "streetAddress": "Ξενοφώντος 15Α",
              "addressLocality": "Αθήνα",
              "postalCode": "10557",
              "addressCountry": "GR"
            },
            "medicalSpecialty": "Psychiatric",
            "memberOf": [
              {"@type": "Organization", "name": "American Psychiatric Association (APA)"},
              {"@type": "Organization", "name": "Hellenic American Psychiatric Association (HAPA)"},
              {"@type": "Organization", "name": "EN.E.PS.E."}
            ]
          },
          {
            "@type": "MedicalWebPage",
            "name": "${title}",
            "headline": "${description}"
          }
        ]
      }
    `} />
  </head>
  <body class="flex flex-col min-h-screen">
    <slot />
  </body>
</html>
