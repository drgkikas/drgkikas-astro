---
import '../styles/global.css';

/* Layout: Added meta tags and SEO optimization */

interface Props {
  title: string;
  description?: string;
  canonicalURL?: string;
  image?: string;
  schema?: string;
}

const { 
  title, 
  description = "Πασχάλης Γκίκας — Ψυχίατρος στην Αθήνα. Εξειδικευμένες υπηρεσίες rTMS, Φαρμακογονιδιωματικής και Ψυχοθεραπείας στο Smart CNS Center.", 
  canonicalURL,
  image = "/images/dr-gkikas-portrait.jpg",
  schema
} = Astro.props;
const canonical = canonicalURL ?? new URL(Astro.url.pathname, 'https://drgkikas.com').href;
const socialImageURL = new URL(image, 'https://drgkikas.com').href;
---

<!doctype html>
<html lang="el" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <!-- Performance Optimization: Preconnect & Font Loading -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://analytics.ahrefs.com">
    <link rel="preconnect" href="https://challenges.cloudflare.com">
    <link rel="preconnect" href="https://maps.googleapis.com">
    <link rel="preconnect" href="https://maps.gstatic.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    </noscript>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    <meta name="description" content={description} />
    
    <!-- OpenGraph Tags -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Πασχάλης Γκίκας | Ψυχίατρος Αθήνα" />
    <meta property="og:locale" content="el_GR" />

    <!-- Twitter Card Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageURL} />
    {Astro.url.hostname.includes('pages.dev') && (
      <meta name="robots" content="noindex, nofollow" />
    )}
    {schema && <script type="application/ld+json" set:html={schema} />}
  </head>
  <body class="flex flex-col min-h-screen">
    <slot />
    
    <!-- Non-critical Scripts: Loaded with async to prevent render blocking -->
    <script src="https://analytics.ahrefs.com/analytics.js" data-key="hKDhDXLoXZvN5sqL6+g1ew" async crossorigin="anonymous"></script>
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
    <script is:inline>
      // Handle Turnstile success event globally
      window.onTurnstileSuccess = function(token) {
        window.dispatchEvent(new CustomEvent('turnstile-success', { detail: { token } }));
      };
    </script>
  </body>
</html>
<!-- Performance Optimized -->
<!-- Webhook Trigger -->
