---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonicalURL?: string;
  image?: string;
}

const { 
  title, 
  description = "Πασχάλης Γκίκας — Ψυχίατρος στην Αθήνα. Εξειδικευμένες υπηρεσίες rTMS, Φαρμακογονιδιωματικής και Ψυχοθεραπείας στο Smart CNS Center.", 
  canonicalURL,
  image = "/images/dr-gkikas-portrait.jpg"
} = Astro.props;
const canonical = canonicalURL ?? new URL(Astro.url.pathname, 'https://drgkikas.gr').href;
const socialImageURL = new URL(image, 'https://drgkikas.gr').href;
---

<!doctype html>
<html lang="el" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    <meta name="description" content={description} />
    
    <!-- OpenGraph Tags -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Πασχάλης Γκίκας | Ψυχίατρος Αθήνα" />

    <!-- Twitter Card Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageURL} />
    {Astro.url.hostname.includes('pages.dev') && (
      <meta name="robots" content="noindex, nofollow" />
    )}
    <script type="application/ld+json" set:html={`
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Physician",
            "name": "Πασχάλης Γκίκας",
            "description": "Ψυχίατρος - Ψυχοθεραπευτής με εξειδίκευση στη Νευροτροποποίηση (rTMS / tDCS) και Φαρμακογονιδιωματική.",
            "url": "https://drgkikas.com",
            "image": "https://drgkikas.com/wp-content/uploads/2021/01/logo.png",
            "telephone": "+302118500016",
            "email": "contact@drgkikas.com",
            "address": {
              "@type": "PostalAddress",
              "streetAddress": "Ξενοφώντος 15Α",
              "addressLocality": "Αθήνα",
              "postalCode": "10557",
              "addressCountry": "GR"
            },
            "medicalSpecialty": "Psychiatric",
            "memberOf": [
              {"@type": "Organization", "name": "American Psychiatric Association (APA)"},
              {"@type": "Organization", "name": "Hellenic American Psychiatric Association (HAPA)"},
              {"@type": "Organization", "name": "EN.E.PS.E."}
            ]
          },
          {
            "@type": "MedicalWebPage",
            "name": "${title}",
            "headline": "${description}"
          }
        ]
      }
    `} />
  </head>
  <body class="flex flex-col min-h-screen">
    <slot />
  </body>
</html>
